# Astro expone al navegador solo variables con PUBLIC_.
# El código también acepta NEXT_PUBLIC_* para que puedas reutilizar tus variables actuales.
PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
PUBLIC_SUPABASE_ANON_KEY=tu_publishable_key

# Opcional, si vienes de Next.js:
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=tu_publishable_key
