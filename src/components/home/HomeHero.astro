---
import './HomeHero.scss';

const {
  copy,
  heroImage = '/images/home-hero.jpg',
  heroImages = [],
  /** URL de video para usar como fondo. Si se provee, reemplaza el slideshow de imágenes. */
  heroVideo = '',
} = Astro.props;

const images = [
  heroImage,
  ...heroImages,
]
  .filter(Boolean)
  .filter((item, index, arr) => arr.indexOf(item) === index)
  .slice(0, 6);

const firstImage = images[0] || heroImage;
---

<section
  class="home-hero"
  aria-label="Bienvenida"
  style={`--hero-first-image: url('${firstImage}');`}
>
  <div class="home-hero__slider" aria-hidden="true">
    {heroVideo ? (
      <>
        <img
          src={firstImage}
          alt=""
          class="home-hero__bg is-active"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
        <video
          class="home-hero__bg"
          data-hero-video={heroVideo}
          preload="none"
          muted
          loop
          playsinline
          poster={firstImage}
        />
      </>
    ) : (
      images.map((image, index) => (
        <img
          src={index === 0 ? image : undefined}
          data-src={index === 0 ? undefined : image}
          alt=""
          class={`home-hero__bg ${index === 0 ? 'is-active' : ''}`}
          loading={index === 0 ? 'eager' : 'lazy'}
          fetchpriority={index === 0 ? 'high' : 'auto'}
          decoding="async"
          data-hero-slide
        />
      ))
    )}
  </div>

  <div class="home-hero__overlay" aria-hidden="true"></div>
  <div class="home-hero__grain" aria-hidden="true"></div>

  <div class="container home-hero__content">
    <p class="home-hero__eyebrow">
      <span class="home-hero__eyebrow-icon" aria-hidden="true">⊙</span>
      {copy.heroEyebrow}
    </p>

    <h1 class="home-hero__title" set:html={copy.heroTitle} />

    <p class="home-hero__subtitle">
      {copy.heroSubtitle}
    </p>

    <div class="home-hero__actions">
      <a href={copy.routes.packages} class="home-hero__btn home-hero__btn--primary">
        {copy.heroPrimary}
        <span>→</span>
      </a>

      <a href={copy.routes.contact} class="home-hero__btn home-hero__btn--ghost">
        {copy.heroSecondary}
        <span>✦</span>
      </a>
    </div>
  </div>

  <div class="home-hero__scroll" aria-hidden="true">
    <span>Descubre</span>
    <div class="home-hero__mouse">
      <span></span>
    </div>
  </div>

  <script is:inline>
    (() => {
      const slides = document.querySelectorAll('[data-hero-slide]');
      const video = document.querySelector('[data-hero-video]');
      let rotationStarted = false;

      // Carga diferida: la primera imagen pinta el hero de inmediato;
      // el resto de slides y el video se descargan recién cuando la
      // página terminó de cargar, sin competir con el contenido visible.
      function hydrateHeroMedia() {
        slides.forEach((img) => {
          if (img.dataset.src) {
            img.src = img.dataset.src;
            delete img.dataset.src;
          }
        });

        if (video && video.dataset.heroVideo) {
          video.src = video.dataset.heroVideo;
          video.autoplay = true;
          video.addEventListener('playing', () => {
            video.classList.add('is-active');
            video.previousElementSibling?.classList.remove('is-active');
          }, { once: true });
          video.play().catch(() => {});
        }

        startRotation();
      }

      function startRotation() {
        if (rotationStarted || slides.length < 2) return;
        rotationStarted = true;

        let current = 0;

        window.setInterval(() => {
          slides[current].classList.remove('is-active');
          current = (current + 1) % slides.length;
          slides[current].classList.add('is-active');
        }, 5200);
      }

      if (document.readyState === 'complete') {
        hydrateHeroMedia();
      } else {
        window.addEventListener('load', hydrateHeroMedia, { once: true });
      }
    })();
  </script>
</section>
