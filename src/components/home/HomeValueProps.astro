---
import './HomeValueProps.scss';

/**
 * Sección "Tour destacado": muestra un tour de prioridad alta en formato
 * editorial (imagen protagonista + ficha) y, debajo, los pilares de la
 * marca como franja compacta. Si no hay tour, solo se muestran los pilares.
 */
const {
  props = [],
  tour = null,
  tourHref = '',
  whatsappUrl = '',
  copy = {},
} = Astro.props;

const labels = {
  eyebrow: 'Experiencia imperdible',
  badge: 'Tour destacado',
  cta: 'Ver este tour',
  secondary: 'Consultar por WhatsApp',
  from: 'Desde',
  perPerson: 'por persona',
  duration: 'Duración',
  destinations: 'Destinos',
  ...copy,
};

const tourImage = tour?.heroImage || tour?.cardImage || '';
const destinationsText = tour?.destinations?.slice(0, 3).join(' · ') || '';
const highlights = (tour?.includes || []).slice(0, 3);
---

<section class="home-featured" aria-label={labels.badge}>
  <div class="container">
    {tour && tourImage && (
      <div class="home-featured__grid">
        <div class="home-featured__media reveal" data-reveal="right">
          <div class="home-featured__frame" aria-hidden="true"></div>

          <figure class="home-featured__figure">
            <img
              src={tourImage}
              alt={tour.title}
              loading="lazy"
              decoding="async"
            />

            <span class="home-featured__badge">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {labels.badge}
            </span>

            {tour.priceFrom && (
              <div class="home-featured__price">
                <small>{labels.from}</small>
                <strong>{tour.currency || 'USD'} {tour.priceFrom}</strong>
                <span>{labels.perPerson}</span>
              </div>
            )}
          </figure>
        </div>

        <div class="home-featured__content reveal" data-reveal="left">
          <p class="home-featured__eyebrow">
            <span class="home-featured__eyebrow-line" aria-hidden="true"></span>
            {labels.eyebrow}
          </p>

          <h2 class="home-featured__title">{tour.title}</h2>

          <p class="home-featured__desc">
            {tour.shortDescription || tour.subtitle || tour.description}
          </p>

          <ul class="home-featured__meta">
            {tour.durationText && (
              <li>
                <span class="home-featured__meta-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                </span>
                <span class="home-featured__meta-text">
                  <small>{labels.duration}</small>
                  {tour.durationText}
                </span>
              </li>
            )}

            {destinationsText && (
              <li>
                <span class="home-featured__meta-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                </span>
                <span class="home-featured__meta-text">
                  <small>{labels.destinations}</small>
                  {destinationsText}
                </span>
              </li>
            )}
          </ul>

          {highlights.length > 0 && (
            <ul class="home-featured__highlights">
              {highlights.map((item) => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          )}

          <div class="home-featured__actions">
            <a href={tourHref} class="home-featured__btn home-featured__btn--primary">
              {labels.cta}
              <span aria-hidden="true">→</span>
            </a>

            {whatsappUrl && (
              <a
                href={whatsappUrl}
                class="home-featured__btn home-featured__btn--ghost"
                target="_blank"
                rel="noopener noreferrer"
              >
                {labels.secondary}
              </a>
            )}
          </div>
        </div>
      </div>
    )}

    <div class={`home-featured__props ${tour && tourImage ? '' : 'home-featured__props--solo'}`}>
      {props.map((item, index) => (
        <article class="home-featured__prop reveal" style={`transition-delay:${index * 0.08}s`}>
          <span class="home-featured__prop-icon" aria-hidden="true">{item.icon}</span>
          <div class="home-featured__prop-body">
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
