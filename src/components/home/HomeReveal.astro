<script is:inline>
(function () {
  // Skip animations for users who prefer reduced motion
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('.reveal').forEach(function (el) {
      el.classList.add('is-visible');
    });
    return;
  }

  document.documentElement.classList.add('has-reveal');

  // ── Reveal on scroll ──────────────────────────────────────────
  var items = document.querySelectorAll('.reveal');

  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.06, rootMargin: '0px 0px -30px 0px' }
    );
    items.forEach(function (el) { io.observe(el); });
  } else {
    items.forEach(function (el) { el.classList.add('is-visible'); });
  }

  // ── Reveal para elementos [data-reveal] (global.scss los oculta) ──
  var dataRevealItems = document.querySelectorAll('[data-reveal]');

  if ('IntersectionObserver' in window) {
    var dataIo = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            var delay = e.target.getAttribute('data-reveal-delay');
            if (delay) e.target.style.transitionDelay = delay + 'ms';
            e.target.classList.add('is-visible');
            dataIo.unobserve(e.target);
          }
        });
      },
      { threshold: 0.06, rootMargin: '0px 0px -30px 0px' }
    );
    dataRevealItems.forEach(function (el) { dataIo.observe(el); });
  } else {
    dataRevealItems.forEach(function (el) { el.classList.add('is-visible'); });
  }

  // ── Parallax ──────────────────────────────────────────────────
  var heroBg      = document.querySelector('.home-hero__bg');
  var parallaxEls = Array.from(document.querySelectorAll('[data-parallax]'));
  var ticking     = false;

  function applyParallax() {
    var y  = window.scrollY;
    var vh = window.innerHeight;

    if (heroBg && y < vh * 1.6) {
      heroBg.style.transform = 'scale(1.08) translateY(' + (y * 0.22) + 'px)';
    }

    parallaxEls.forEach(function (el) {
      var speed  = parseFloat(el.dataset.parallax) || 0.12;
      var rect   = el.getBoundingClientRect();
      var offset = (rect.top + rect.height / 2 - vh / 2) * speed;
      el.style.transform = 'translateY(' + offset + 'px)';
    });

    ticking = false;
  }

  window.addEventListener('scroll', function () {
    if (!ticking) {
      requestAnimationFrame(applyParallax);
      ticking = true;
    }
  }, { passive: true });

  applyParallax();
})();
</script>

<style is:global>
  /* ── Fallback: visible without JS ───────────────────────────── */
  .reveal { opacity: 1; transform: none; }

  /* ── JS-enhanced base ────────────────────────────────────────── */
  .has-reveal .reveal {
    opacity: 0;
    transition:
      opacity  0.85s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* ── Hidden-state transforms (only before is-visible) ────────── */
  /* default: slide up */
  .has-reveal .reveal:not(.is-visible):not([data-reveal]),
  .has-reveal .reveal:not(.is-visible)[data-reveal="up"] {
    transform: translateY(56px);
  }

  /* slide in from the right  → element comes from the right */
  .has-reveal .reveal:not(.is-visible)[data-reveal="left"] {
    transform: translateX(60px);
  }

  /* slide in from the left   → element comes from the left */
  .has-reveal .reveal:not(.is-visible)[data-reveal="right"] {
    transform: translateX(-60px);
  }

  /* scale + lift */
  .has-reveal .reveal:not(.is-visible)[data-reveal="scale"] {
    transform: scale(0.86) translateY(24px);
  }

  /* fade only */
  .has-reveal .reveal:not(.is-visible)[data-reveal="fade"] {
    transform: none;
  }

  /* ── Visible state ───────────────────────────────────────────── */
  .has-reveal .reveal.is-visible {
    opacity: 1;
    /* no transform override → lets hover transforms work freely */
  }

  /* ── Parallax elements ───────────────────────────────────────── */
  [data-parallax] { will-change: transform; }

  /* ── Shared parallax orb ─────────────────────────────────────── */
  .parallax-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform;
  }
</style>
