---
import type { Destination, Region, RegionSlug } from '@/types/content';
import { getLocaleFromUrl } from '@/lib/i18n';
import PeruDepartmentsMap from '@/components/maps/PeruDepartmentsMap.astro';
import './PeruRegionMap.scss';

interface Props {
  destinations: Destination[];
  region?: RegionSlug;
  title?: string;
  subtitle?: string;
  allRegions?: Region[];
}

const {
  destinations = [],
  region,
  title = 'Mapa del Perú',
  subtitle = 'Explora los destinos disponibles.',
  allRegions = [],
} = Astro.props;

// Todas las regiones; la actual se marca como activa en el template
const navRegions = allRegions;

const currentLocale = getLocaleFromUrl(Astro.url.pathname);

const destinationBase =
  currentLocale === 'es' ? '/destinos' : `/${currentLocale}/destinations`;

const regionBase =
  currentLocale === 'es' ? '/regiones' : `/${currentLocale}/regions`;

const pins = destinations.filter(
  (destination) =>
    typeof destination.mapX === 'number' &&
    typeof destination.mapY === 'number'
);

const activeRegion = region || 'all';
---

<section class="peru-map-section">
  <div class="peru-map-section__intro">
    <p class="peru-map-section__eyebrow">Mapa interactivo</p>

    <h2 class="peru-map-section__title">{title}</h2>

    <p class="peru-map-section__subtitle">{subtitle}</p>

    {navRegions.length > 0 && (
      <div class="peru-map-section__other-regions">
        <p class="peru-map-section__other-label">Explorar regiones</p>

        <div class="peru-map-section__region-cards">
          {navRegions.map((r) => (
            <a
              href={`${regionBase}/${r.slug}`}
              class={`region-nav-card region-nav-card--${r.slug}${r.slug === region ? ' is-current' : ''}`}
              aria-current={r.slug === region ? 'page' : undefined}
            >
              <div class="region-nav-card__img-wrap">
                <img
                  src={r.cardImage}
                  alt={r.name}
                  loading="lazy"
                  draggable="false"
                />
              </div>

              <div class="region-nav-card__text">
                <span class="region-nav-card__name">{r.name}</span>
                <span class="region-nav-card__headline">{r.headline}</span>
              </div>

              <svg
                class="region-nav-card__arrow"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <polyline points="9 18 15 12 9 6" />
              </svg>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>

  <div class={`peru-map peru-map--${activeRegion}`}>
    <div class="peru-map__wrapper" data-active-region={activeRegion}>
      <PeruDepartmentsMap activeRegion={region} />

      <div class="peru-map__pins">
        {pins.map((destination) => (
          <a
            href={`${destinationBase}/${destination.slug}`}
            class="peru-map__pin"
            style={`--x:${destination.mapX}%; --y:${destination.mapY}%`}
            aria-label={`Ver ${destination.name}`}
            data-region={destination.region}
          >
            <span class="peru-map__pin-dot" aria-hidden="true"></span>

            <div class="peru-map__pin-card" aria-hidden="true">
              <div class="peru-map__pin-photo-wrap">
                <img
                  src={destination.cardImage}
                  alt={destination.name}
                  class="peru-map__pin-photo"
                  loading="lazy"
                  draggable="false"
                />
              </div>

              <span class="peru-map__pin-name">{destination.name}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>