---
import { site } from '@/lib/site';
import { getLocaleFromUrl } from '@/lib/i18n';
import './Footer.scss';

const locale = getLocaleFromUrl(Astro.url.pathname);

const prefix = locale === 'es' ? '' : `/${locale}`;

const routes = {
  packages:     locale === 'es' ? '/paquetes'  : `${prefix}/packages`,
  tours:        locale === 'es' ? '/tours'     : `${prefix}/tours`,
  destinations: locale === 'es' ? '/destinos'  : `${prefix}/destinations`,
  about:        locale === 'es' ? '/nosotros'  : `${prefix}/about`,
  contact:      locale === 'es' ? '/contacto'  : `${prefix}/contact`,
  privacy:      locale === 'es' ? '/politica-de-privacidad'   : `${prefix}/privacy-policy`,
  terms:        locale === 'es' ? '/terminos-y-condiciones'   : `${prefix}/terms`,
};

const labels = {
  es: {
    statement: ['El ', 'alma', ' del ', 'Perú', 'en cada destino.'],
    cta: 'Diseñar mi viaje',
    brandDesc: 'Diseñamos experiencias de viaje por todo el Perú, conectando cultura, naturaleza, territorio y atención personalizada.',
    explore: 'Explorar',
    packages: 'Paquetes',
    tours: 'Tours',
    destinations: 'Destinos',
    about: 'Nosotros',
    destinationsCol: 'Destinos',
    coast: 'Costa',
    sierra: 'Sierra',
    jungle: 'Selva',
    contactCol: 'Contacto',
    hours: 'Lun. a Sáb. 9:00 — 18:00',
    copyright: '© 2026 Nuna Terra Perú · Todos los derechos reservados',
    privacy: 'Política de privacidad',
    terms: 'Términos y condiciones',
  },
  en: {
    statement: ['The ', 'soul', ' of ', 'Peru', 'in every destination.'],
    cta: 'Design my trip',
    brandDesc: 'We design travel experiences across Peru, connecting culture, nature, territory and personalized attention.',
    explore: 'Explore',
    packages: 'Packages',
    tours: 'Tours',
    destinations: 'Destinations',
    about: 'About us',
    destinationsCol: 'Destinations',
    coast: 'Coast',
    sierra: 'Andes',
    jungle: 'Amazon',
    contactCol: 'Contact',
    hours: 'Mon. to Sat. 9:00 — 18:00',
    copyright: '© 2026 Nuna Terra Perú · All rights reserved',
    privacy: 'Privacy policy',
    terms: 'Terms and conditions',
  },
  pt: {
    statement: ['A ', 'alma', ' do ', 'Peru', 'em cada destino.'],
    cta: 'Desenhar minha viagem',
    brandDesc: 'Desenhamos experiências de viagem por todo o Peru, conectando cultura, natureza, território e atenção personalizada.',
    explore: 'Explorar',
    packages: 'Pacotes',
    tours: 'Tours',
    destinations: 'Destinos',
    about: 'Sobre nós',
    destinationsCol: 'Destinos',
    coast: 'Costa',
    sierra: 'Serra',
    jungle: 'Selva',
    contactCol: 'Contato',
    hours: 'Seg. a Sáb. 9:00 — 18:00',
    copyright: '© 2026 Nuna Terra Perú · Todos os direitos reservados',
    privacy: 'Política de privacidade',
    terms: 'Termos e condições',
  },
  fr: {
    statement: ["L'", 'âme', ' du ', 'Pérou', 'dans chaque destination.'],
    cta: 'Créer mon voyage',
    brandDesc: 'Nous créons des expériences de voyage à travers tout le Pérou, en connectant culture, nature, territoire et attention personnalisée.',
    explore: 'Explorer',
    packages: 'Forfaits',
    tours: 'Tours',
    destinations: 'Destinations',
    about: 'À propos',
    destinationsCol: 'Destinations',
    coast: 'Côte',
    sierra: 'Andes',
    jungle: 'Amazonie',
    contactCol: 'Contact',
    hours: 'Lun. au Sam. 9:00 — 18:00',
    copyright: '© 2026 Nuna Terra Perú · Tous droits réservés',
    privacy: 'Politique de confidentialité',
    terms: 'Conditions générales',
  },
}[locale];
---

<footer class="footer">
  <div class="footer-art" aria-hidden="true">
    <img src="/images/footer.svg" alt="" loading="lazy" />
  </div>

  <div class="footer-main">
    <div class="footer-content container">

      <div class="footer-statement">
        <span class="footer-statement__quote">
          {labels.statement[0]}<em>{labels.statement[1]}</em>{labels.statement[2]}<em>{labels.statement[3]}</em><br />{labels.statement[4]}
        </span>

        <a href={site.whatsappUrl} class="footer-statement__cta" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.118 1.532 5.845L.057 23.455a.5.5 0 0 0 .612.612l5.605-1.476A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.9a9.877 9.877 0 0 1-5.03-1.373l-.36-.214-3.73.982.997-3.64-.235-.374A9.861 9.861 0 0 1 2.1 12C2.1 6.534 6.534 2.1 12 2.1S21.9 6.534 21.9 12 17.466 21.9 12 21.9z"/>
          </svg>
          {labels.cta}
        </a>
      </div>

      <div class="footer-grid">

        <div class="footer-col footer-brand">
          <img
            class="footer-brand__logo"
            src="/icons/isotopo.svg"
            alt="Nuna Terra Perú"
            width="180"
            height="130"
            loading="eager"
          />

          <p class="footer-brand__desc">{labels.brandDesc}</p>

          <div class="socials">
            <a href={site.socials.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>

            <a href={site.socials.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>

            <a href={site.socials.tiktok} target="_blank" rel="noopener noreferrer" aria-label="TikTok">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
              </svg>
            </a>

            <a href={site.whatsappUrl} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.118 1.532 5.845L.057 23.455a.5.5 0 0 0 .612.612l5.605-1.476A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.9a9.877 9.877 0 0 1-5.03-1.373l-.36-.214-3.73.982.997-3.64-.235-.374A9.861 9.861 0 0 1 2.1 12C2.1 6.534 6.534 2.1 12 2.1S21.9 6.534 21.9 12 17.466 21.9 12 21.9z"/>
              </svg>
            </a>

            <a href={site.socials.tripadvisor} target="_blank" rel="noopener noreferrer" aria-label="TripAdvisor">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 3.6c1.98 0 3.84.54 5.43 1.47L19.2 3.6h-1.35A10.22 10.22 0 0 0 12 2.1 10.22 10.22 0 0 0 6.15 3.6H4.8l1.77 1.47A10.16 10.16 0 0 0 12 3.6zM6.9 9.3a3 3 0 1 1 0 6 3 3 0 0 1 0-6zm10.2 0a3 3 0 1 1 0 6 3 3 0 0 1 0-6zM6.9 10.8a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zm10.2 0a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zM12 10.35l-1.5 2.55 1.5.9 1.5-.9-1.5-2.55z"/>
              </svg>
            </a>

            <a href={site.socials.googleMaps} target="_blank" rel="noopener noreferrer" aria-label="Google Maps">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                <circle cx="12" cy="9" r="2.5"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="footer-col">
          <h4>{labels.explore}</h4>
          <ul>
            <li><a href={routes.packages}>{labels.packages}</a></li>
            <li><a href={routes.tours}>{labels.tours}</a></li>
            <li><a href={routes.destinations}>{labels.destinations}</a></li>
            <li><a href={routes.about}>{labels.about}</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>{labels.destinationsCol}</h4>
          <ul>
            <li><a href={`${routes.destinations}/costa`}>{labels.coast}</a></li>
            <li><a href={`${routes.destinations}/sierra`}>{labels.sierra}</a></li>
            <li><a href={`${routes.destinations}/selva`}>{labels.jungle}</a></li>
            <li><a href={`${routes.destinations}/cusco`}>Cusco</a></li>
          </ul>
        </div>

        <div class="footer-col footer-contact">
          <h4>{labels.contactCol}</h4>
          <ul>
            <li><a href={site.whatsappUrl}>{site.whatsapp}</a></li>
            <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
            <li><span>{site.location}</span></li>
            <li><span>{labels.hours}</span></li>
          </ul>
        </div>

      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>{labels.copyright}</p>
    <div class="footer-legal">
      <a href={routes.privacy}>{labels.privacy}</a>
      <span aria-hidden="true">·</span>
      <a href={routes.terms}>{labels.terms}</a>
    </div>
  </div>
</footer>