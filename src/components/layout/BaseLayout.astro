---
import Header from './Header.astro';
import Footer from './Footer.astro';
import '@/styles/global.scss';
import { getLocaleFromUrl } from '@/lib/i18n';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Nuna Terra Perú',
  description = 'El alma del Perú en cada destino.'
} = Astro.props;

const locale = getLocaleFromUrl(Astro.url.pathname);

const skipLink = {
  es: 'Ir al contenido principal',
  en: 'Skip to main content',
  pt: 'Ir para o conteúdo principal',
  fr: 'Aller au contenu principal',
}[locale];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/svg+xml" href="/icons/isotopo.svg" />
    <link rel="shortcut icon" href="/icons/isotopo.svg" type="image/svg+xml" />

    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/og-image.jpg" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <title>{title}</title>
  </head>

  <body>
    <a class="skip-link" href="#main-content">{skipLink}</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>