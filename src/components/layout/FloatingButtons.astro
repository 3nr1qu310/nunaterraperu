---
import { site } from '@/lib/site';
---

<div class="float-btns" aria-label="Contacto rápido">
  <a
    href={site.whatsappUrl}
    class="float-btn float-btn--wa"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Contactar por WhatsApp"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.118 1.532 5.845L.057 23.455a.5.5 0 0 0 .612.612l5.605-1.476A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.9a9.877 9.877 0 0 1-5.03-1.373l-.36-.214-3.73.982.997-3.64-.235-.374A9.861 9.861 0 0 1 2.1 12C2.1 6.534 6.534 2.1 12 2.1S21.9 6.534 21.9 12 17.466 21.9 12 21.9z"/>
    </svg>
    <span class="float-btn__label">WhatsApp</span>
  </a>

  <a
    href={`mailto:${site.email}`}
    class="float-btn float-btn--mail"
    aria-label="Enviar un correo"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="4" width="20" height="16" rx="2"/>
      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
    </svg>
    <span class="float-btn__label">Correo</span>
  </a>
</div>

<style>
  .float-btns {
    position: fixed;
    bottom: 28px;
    right: 24px;
    z-index: 900;
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-end;
  }

  .float-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 18px 0 0;
    height: 52px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    white-space: nowrap;
    overflow: hidden;
    max-width: 52px;
    transition:
      max-width 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.25s ease,
      transform 0.22s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.18);

    svg {
      width: 22px;
      height: 22px;
      flex-shrink: 0;
      margin-left: 15px;
    }
  }

  .float-btn:hover {
    max-width: 200px;
    transform: translateY(-2px);
  }

  .float-btn:active {
    transform: scale(0.97);
  }

  .float-btn__label {
    opacity: 0;
    transition: opacity 0.2s ease 0.1s;
    padding-right: 4px;
  }

  .float-btn:hover .float-btn__label {
    opacity: 1;
  }

  .float-btn--wa {
    background: #25d366;
    color: #fff;
  }

  .float-btn--wa:hover {
    background: #1ebe5d;
    box-shadow: 0 6px 28px rgba(37, 211, 102, 0.4);
  }

  .float-btn--mail {
    background: #5a3e2b;
    color: #f7f1e7;
  }

  .float-btn--mail:hover {
    background: #4a3222;
    box-shadow: 0 6px 28px rgba(90, 62, 43, 0.35);
  }

  /* Con la tabbar inferior visible (≤960px) los botones suben para no taparla */
  @media (max-width: 960px) {
    .float-btns {
      bottom: calc(72px + env(safe-area-inset-bottom, 0px));
    }
  }

  @media (max-width: 480px) {
    .float-btns {
      bottom: calc(68px + env(safe-area-inset-bottom, 0px));
      right: 16px;
      gap: 10px;
    }

    .float-btn {
      height: 48px;
      max-width: 48px;

      svg {
        width: 20px;
        height: 20px;
        margin-left: 14px;
      }
    }

    .float-btn:hover {
      max-width: 170px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .float-btn,
    .float-btn__label {
      transition: none;
    }
  }
</style>
