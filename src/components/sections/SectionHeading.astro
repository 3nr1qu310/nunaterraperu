---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  centered?: boolean;
  align?: 'left' | 'center';
  theme?: 'light' | 'dark';
}

const {
  eyebrow,
  title,
  subtitle,
  centered = false,
  align = centered ? 'center' : 'left',
  theme = 'light',
} = Astro.props;

const isCenter = centered || align === 'center';
---

<header
  class:list={[
    'section-heading',
    `section-heading--${theme}`,
    { 'section-heading--center': isCenter },
  ]}
>
  {eyebrow && (
    <p class="section-heading__eyebrow">
      {eyebrow}
    </p>
  )}

  <h2 class="section-heading__title">
    {title}
  </h2>

  {subtitle && (
    <p class="section-heading__subtitle">
      {subtitle}
    </p>
  )}
</header>

<style lang="scss">
  .section-heading {
    margin-bottom: 38px;
  }

  .section-heading--center {
    text-align: center;
    display: grid;
    justify-items: center;
  }

  .section-heading__eyebrow {
    margin: 0 0 12px;
    color: var(--color-green);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .section-heading__title {
    max-width: 820px;
    margin: 0;
    color: var(--color-earth);
    font-family: var(--font-display);
    font-size: clamp(2.35rem, 4vw, 4rem);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: -0.02em;
  }

  .section-heading__subtitle {
    max-width: 720px;
    margin: 16px 0 0;
    color: rgba(37, 37, 37, 0.68);
    font-size: 1.02rem;
    line-height: 1.7;
  }

  .section-heading--dark .section-heading__eyebrow {
    color: var(--color-sand);
  }

  .section-heading--dark .section-heading__title {
    color: var(--color-ivory);
  }

  .section-heading--dark .section-heading__subtitle {
    color: rgba(247, 241, 231, 0.72);
  }

  @media (max-width: 640px) {
    .section-heading {
      margin-bottom: 28px;
    }

    .section-heading__title {
      font-size: clamp(2rem, 10vw, 3rem);
    }

    .section-heading__subtitle {
      font-size: 0.96rem;
    }
  }
</style>