---
interface Props { eyebrow?: string; title: string; subtitle?: string; centered?: boolean; }
const { eyebrow, title, subtitle, centered = false } = Astro.props;
---
<header class:list={['section-heading', { 'section-heading--center': centered }]}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="h2">{title}</h2>
  {subtitle && <p class="lead">{subtitle}</p>}
</header>
<style lang="scss">
.section-heading { margin-bottom: 38px; }
.section-heading--center { text-align: center; display: grid; justify-items: center; }
</style>
