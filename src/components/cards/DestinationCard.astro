---
import type { Destination } from '@/types/content';
import { getLocaleFromUrl } from '@/lib/i18n';
import './DestinationCard.scss';

interface Props {
  destination: Destination;
  size?: 'large' | 'compact';
}

const { destination, size = 'large' } = Astro.props;

const currentLocale = getLocaleFromUrl(Astro.url.pathname);

const href =
  currentLocale === 'es'
    ? `/destinos/${destination.slug}`
    : `/${currentLocale}/destinations/${destination.slug}`;

const image =
  destination.cardImage ||
  destination.heroImage ||
  '/images/placeholders/destination-placeholder.jpg';

const regionLabel =
  destination.region === 'costa'
    ? 'Costa'
    : destination.region === 'sierra'
      ? 'Sierra'
      : destination.region === 'selva'
        ? 'Selva'
        : destination.region || '';

const ctaLabel =
  currentLocale === 'es'
    ? 'Explorar destino'
    : currentLocale === 'pt'
      ? 'Explorar destino'
      : currentLocale === 'fr'
        ? 'Explorer la destination'
        : 'Explore destination';

const description =
  destination.shortDescription ||
  destination.subtitle ||
  destination.description ||
  '';

const meta =
  destination.bestTime ||
  destination.recommendedDays ||
  destination.altitude ||
  '';

const compactMeta = [
  regionLabel,
  meta,
].filter(Boolean).join(' · ');
---

<article class={`destination-card destination-card--${size}`}>
  <a href={href} class="destination-card__link" aria-label={`${ctaLabel}: ${destination.name}`}>
    {size === 'large' ? (
      <>
        <img
          class="destination-card__image"
          src={image}
          alt={destination.name}
          loading="lazy"
        />

        <div class="destination-card__shade"></div>

        <div class="destination-card__content">
          <span class="destination-card__region">
            {regionLabel} · Destino destacado
          </span>

          <h3 class="destination-card__title">{destination.name}</h3>

          <p class="destination-card__description">
            {description}
          </p>

          <b class="destination-card__cta">
            {ctaLabel}
            <span>→</span>
          </b>
        </div>
      </>
    ) : (
      <>
        <div class="destination-card__thumb">
          <img
            src={image}
            alt={destination.name}
            loading="lazy"
          />
        </div>

        <div class="destination-card__compact-body">
          <h3>{destination.name}</h3>

          <span>
            {compactMeta}
          </span>

          <b>→</b>
        </div>
      </>
    )}
  </a>
</article>