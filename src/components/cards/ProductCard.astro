---
import type { Product } from '@/types/content';
import { getLocaleFromUrl } from '@/lib/i18n';
import './ProductCard.scss';

interface Props {
  product: Product;
}

const { product } = Astro.props;

const currentLocale = getLocaleFromUrl(Astro.url.pathname);

const href =
  product.type === 'package'
    ? currentLocale === 'es'
      ? `/paquetes/${product.slug}`
      : `/${currentLocale}/packages/${product.slug}`
    : currentLocale === 'es'
      ? `/tours/${product.slug}`
      : `/${currentLocale}/tours/${product.slug}`;

const image =
  product.cardImage ||
  product.heroImage ||
  '/images/placeholders/package-placeholder.jpg';

const typeLabel =
  product.type === 'package'
    ? currentLocale === 'es'
      ? 'Paquete'
      : currentLocale === 'pt'
        ? 'Pacote'
        : currentLocale === 'fr'
          ? 'Forfait'
          : 'Package'
    : 'Tour';

const fromLabel =
  currentLocale === 'es'
    ? 'Desde'
    : currentLocale === 'pt'
      ? 'A partir de'
      : currentLocale === 'fr'
        ? 'À partir de'
        : 'From';

const ctaLabel =
  currentLocale === 'es'
    ? 'Ver experiencia'
    : currentLocale === 'pt'
      ? 'Ver experiência'
      : currentLocale === 'fr'
        ? 'Voir l’expérience'
        : 'View experience';

const destinationText = product.destinations?.length
  ? product.destinations.join(' · ')
  : currentLocale === 'es'
    ? 'Ruta personalizada'
    : currentLocale === 'pt'
      ? 'Rota personalizada'
      : currentLocale === 'fr'
        ? 'Itinéraire personnalisé'
        : 'Tailor-made route';
---

<article class="product-card">
  <a href={href} class="product-card__link" aria-label={`${ctaLabel}: ${product.title}`}>
    <div class="product-card__media">
      <img
        class="product-card__image"
        src={image}
        alt={product.title}
        loading="lazy"
        decoding="async"
      />

      <div class="product-card__shade"></div>

      <span class="product-card__tag">
        {typeLabel}
      </span>

      {product.featured && (
        <span class="product-card__featured" aria-label="Destacado">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </span>
      )}
    </div>

    <div class="product-card__body">
      <div class="product-card__topline">
        <span>{product.durationText || 'Flexible'}</span>
      </div>

      <h3 class="product-card__title">
        {product.title}
      </h3>

      <p class="product-card__subtitle">
        {product.subtitle || product.shortDescription}
      </p>

      <div class="product-card__meta">
        <span class="product-card__meta-icon" aria-hidden="true">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        </span>
        <span>{destinationText}</span>
      </div>

      <div class="product-card__footer">
        {product.priceFrom ? (
          <strong class="product-card__price">
            <small>{fromLabel}</small>
            {product.currency || 'USD'} {product.priceFrom}
          </strong>
        ) : (
          <strong class="product-card__price product-card__price--empty">
            <small>{fromLabel}</small>
            Consultar
          </strong>
        )}

        <span class="product-card__cta">
          {ctaLabel}
          <span>→</span>
        </span>
      </div>

      {product.promotions && product.promotions.length > 0 && (
        <div class="product-card__promotions">
          {product.promotions.slice(0, 2).map((promo) => {
            const badge = promo.customBadge || promo.badgeText || promo.title;
            const discount =
              promo.discountValue && promo.discountType === 'percentage'
                ? `${promo.discountValue}% OFF`
                : promo.discountValue && promo.discountType === 'fixed'
                  ? `${promo.discountValue} OFF`
                  : '';
            const label = discount ? `${badge} · ${discount}` : badge;
            return (
              <span class="product-card__promo-badge">
                {label}
              </span>
            );
          })}
        </div>
      )}
    </div>
  </a>
</article>