---
import AdminLayout from '@/components/admin/AdminLayout.astro';
---

<AdminLayout title="Tours | Admin">
  <div class="admin-page-head">
    <div>
      <p class="eyebrow">Contenido turístico</p>
      <h1 class="h2">Tours</h1>
      <p class="lead">Administra tours de uno o dos días, full day y experiencias cortas.</p>
    </div>

    <a class="btn btn--primary" href="/admin/paquetes/editar?type=tour">
      Crear tour
    </a>
  </div>

  <div class="admin-toolbar">
    <div class="admin-search">
      <span aria-hidden="true">⌕</span>
      <input
        id="search"
        placeholder="Buscar tour por nombre o slug..."
      />
    </div>
  </div>

  <div class="admin-panel admin-table-wrap">
    <table class="admin-table admin-products-table">
      <thead>
        <tr>
          <th>Imagen</th>
          <th>Estado</th>
          <th>Nombre</th>
          <th>Duración</th>
          <th>Precio</th>
          <th>Dificultad</th>
          <th>Acciones</th>
        </tr>
      </thead>

      <tbody id="rows">
        <tr>
          <td colspan="7">Cargando...</td>
        </tr>
      </tbody>
    </table>
  </div>

  <style>
    .admin-page-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 24px;
      margin-bottom: 22px;
    }

    .admin-toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 18px;
    }

    .admin-search {
      width: min(100%, 420px);
      min-height: 46px;
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0 14px;
      border: 1px solid rgba(90, 62, 43, 0.16);
      border-radius: 999px;
      background: #fff;
      box-shadow: 0 8px 20px rgba(37, 37, 37, 0.035);
    }

    .admin-search span {
      color: rgba(90, 62, 43, 0.48);
      font-size: 1.05rem;
    }

    .admin-search input {
      width: 100%;
      min-width: 0;
      border: 0;
      outline: 0;
      background: transparent;
      color: #252525;
      font: inherit;
      font-size: 0.94rem;
    }

    .admin-products-table td {
      vertical-align: middle;
    }

    .admin-thumb {
      width: 86px;
      height: 58px;
      border-radius: 12px;
      overflow: hidden;
      background: rgba(90, 62, 43, 0.08);
      border: 1px solid rgba(90, 62, 43, 0.1);
      display: grid;
      place-items: center;
    }

    .admin-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .admin-thumb span {
      font-size: 11px;
      color: rgba(37, 37, 37, 0.55);
      text-align: center;
      padding: 6px;
      line-height: 1.2;
    }

    .admin-product-name {
      display: grid;
      gap: 4px;
      min-width: 220px;
    }

    .admin-product-name strong {
      color: #5A3E2B;
      line-height: 1.25;
    }

    .admin-row-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }

    .admin-danger {
      color: #8a3a2b;
    }

    @media (max-width: 820px) {
      .admin-page-head {
        display: grid;
        align-items: start;
      }

      .admin-page-head .btn {
        width: fit-content;
      }

      .admin-toolbar {
        display: grid;
      }

      .admin-search {
        width: 100%;
      }
    }
  </style>

  <script>
    import { adminSupabase, notify } from '@/lib/admin-client';

    let products = [];

    const rows = document.querySelector('#rows');
    const search = document.querySelector('#search') as HTMLInputElement | null;

    function escapeHtml(value = '') {
      return String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    function imageCell(product: Record<string, string>) {
      const imageUrl = product.card_image_url || product.hero_image_url || '';

      if (!imageUrl) {
        return `
          <div class="admin-thumb">
            <span>Sin imagen</span>
          </div>
        `;
      }

      return `
        <div class="admin-thumb">
          <img
            src="${escapeHtml(imageUrl)}"
            alt="${escapeHtml(product.title || 'Tour')}"
            loading="lazy"
            onerror="this.parentElement.innerHTML='<span>Imagen no disponible</span>'"
          />
        </div>
      `;
    }

    function render() {
      const term = (search?.value || '').toLowerCase().trim();

      const filtered = products.filter((p) => {
        const title = (p.title || '').toLowerCase();
        const slug = (p.slug || '').toLowerCase();

        return title.includes(term) || slug.includes(term);
      });

      rows.innerHTML = filtered.length
        ? filtered.map((p) => `
          <tr>
            <td>
              ${imageCell(p)}
            </td>

            <td>
              <span class="admin-pill ${p.status !== 'published' ? 'admin-pill--draft' : ''}">
                ${escapeHtml(p.status || 'draft')}
              </span>
            </td>

            <td>
              <div class="admin-product-name">
                <strong>${escapeHtml(p.title || 'Sin título')}</strong>
                <span class="admin-muted">/${escapeHtml(p.slug || '')}</span>
              </div>
            </td>

            <td>${escapeHtml(p.duration_text || '—')}</td>

            <td>
              ${escapeHtml(p.currency || 'USD')} ${p.price_from ?? '—'}
            </td>

            <td>${escapeHtml(p.difficulty_level || '—')}</td>

            <td>
              <div class="admin-row-actions">
                <a class="admin-link" href="/admin/paquetes/editar?id=${p.id}">
                  Editar
                </a>

                <button
                  type="button"
                  class="admin-link"
                  data-toggle="${p.id}"
                  data-status="${p.status}"
                >
                  ${p.status === 'published' ? 'Pasar a borrador' : 'Publicar'}
                </button>

                <button
                  type="button"
                  class="admin-link admin-danger"
                  data-delete="${p.id}"
                >
                  Archivar
                </button>
              </div>
            </td>
          </tr>
        `).join('')
        : '<tr><td colspan="7">No hay tours.</td></tr>';

      document.querySelectorAll('[data-toggle]').forEach((btn) => {
        btn.addEventListener('click', toggleStatus);
      });

      document.querySelectorAll('[data-delete]').forEach((btn) => {
        btn.addEventListener('click', archiveProduct);
      });
    }

    async function load() {
      const { data, error } = await adminSupabase
        .from('products')
        .select('id, title, slug, product_type, status, duration_text, currency, price_from, difficulty_level, card_image_url, hero_image_url, is_active, created_at')
        .eq('product_type', 'tour')
        .order('created_at', { ascending: false });

      if (error) {
        return notify(error.message, 'error');
      }

      products = data || [];
      render();
    }

    async function toggleStatus(event: Event) {
      const target = event.currentTarget as HTMLElement;
      const id = target.dataset.toggle;
      const currentStatus = target.dataset.status;
      const status = currentStatus === 'published' ? 'draft' : 'published';

      const { error } = await adminSupabase
        .from('products')
        .update({
          status,
          is_active: status === 'published',
          updated_at: new Date().toISOString(),
        })
        .eq('id', id);

      if (error) {
        return notify(error.message, 'error');
      }

      notify('Estado actualizado.', 'success');
      await load();
    }

    async function archiveProduct(event: Event) {
      if (!confirm('¿Archivar este tour?')) return;

      const target = event.currentTarget as HTMLElement;

      const { error } = await adminSupabase
        .from('products')
        .update({
          status: 'archived',
          is_active: false,
          updated_at: new Date().toISOString(),
        })
        .eq('id', target.dataset.delete);

      if (error) {
        return notify(error.message, 'error');
      }

      notify('Tour archivado.', 'success');
      await load();
    }

    search?.addEventListener('input', render);

    window.setTimeout(load, 250);
  </script>
</AdminLayout>