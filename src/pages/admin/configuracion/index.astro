---
import AdminLayout from '@/components/admin/AdminLayout.astro';
import MediaPicker from '@/components/admin/MediaPicker.astro';
---

<AdminLayout title="Configuración web | Admin">
  <p class="eyebrow">Configuración</p>
  <h1 class="h2">Hero, contacto y redes</h1>
  <p class="lead">
    Edita textos globales, datos de contacto e imágenes principales. Se guardan en la tabla site_settings.
  </p>

  <form id="settingsForm" class="admin-form" style="margin-top:26px">

    <!-- ══════════════════════════════════════════════════
         SECCIÓN: VIDEOS HERO
    ══════════════════════════════════════════════════ -->
    <section class="admin-panel cfg-section">
      <header class="cfg-section__header">
        <div class="cfg-section__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
          </svg>
        </div>
        <div>
          <h2 class="cfg-section__title">Videos de fondo — Heros</h2>
          <p class="admin-muted cfg-section__desc">
            Selecciona un video (o imagen) de la biblioteca para cada página. Usa los filtros <strong>Imágenes</strong> / <strong>Videos</strong> dentro del selector. Deja vacío para mantener la imagen estática por defecto.
          </p>
        </div>
      </header>

      <div class="cfg-media-grid">
        <MediaPicker
          fieldName="home_hero_video"
          label="Video hero — Inicio"
          helperText="Reemplaza el slideshow del home. Sube el video a la biblioteca de medios primero."
        />
        <MediaPicker
          fieldName="nosotros_hero_video"
          label="Video hero — Nosotros"
          helperText="Página «Sobre Nuna Terra Perú»."
        />
        <MediaPicker
          fieldName="contacto_hero_video"
          label="Video hero — Contacto"
          helperText="Página de contacto y formulario."
        />
        <MediaPicker
          fieldName="paquetes_hero_video"
          label="Video hero — Paquetes"
          helperText="Listado de paquetes turísticos."
        />
        <MediaPicker
          fieldName="tours_hero_video"
          label="Video hero — Tours"
          helperText="Listado de tours y experiencias."
        />
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════
         SECCIÓN: TEXTOS E IMÁGENES
    ══════════════════════════════════════════════════ -->
    <section class="admin-panel cfg-section">
      <header class="cfg-section__header">
        <div class="cfg-section__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
          </svg>
        </div>
        <div>
          <h2 class="cfg-section__title">Textos e imagen principal</h2>
          <p class="admin-muted cfg-section__desc">Título, subtítulo e imagen del hero del home.</p>
        </div>
      </header>

      <div class="admin-form-grid">
        <div class="admin-field">
          <label>Título hero home</label>
          <input name="home_hero_title" />
        </div>
        <div class="admin-field">
          <label>Subtítulo hero home</label>
          <input name="home_hero_subtitle" />
        </div>
      </div>

      <div class="admin-form-grid">
        <MediaPicker
          fieldName="home_hero_image"
          label="Imagen hero home"
          helperText="Imagen de respaldo cuando no hay video configurado."
        />
        <div class="admin-field">
          <label>Texto CTA principal</label>
          <input name="home_cta_text" />
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════
         SECCIÓN: CONTACTO Y REDES
    ══════════════════════════════════════════════════ -->
    <section class="admin-panel cfg-section">
      <header class="cfg-section__header">
        <div class="cfg-section__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.44 2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
        </div>
        <div>
          <h2 class="cfg-section__title">Contacto y redes sociales</h2>
          <p class="admin-muted cfg-section__desc">Datos de contacto visibles en el sitio.</p>
        </div>
      </header>

      <div class="admin-form-grid admin-form-grid--3">
        <div class="admin-field">
          <label>WhatsApp</label>
          <input name="whatsapp_number" />
        </div>
        <div class="admin-field">
          <label>Correo</label>
          <input name="contact_email" />
        </div>
        <div class="admin-field">
          <label>Ubicación</label>
          <input name="contact_location" />
        </div>
      </div>

      <div class="admin-form-grid admin-form-grid--3">
        <div class="admin-field">
          <label>Instagram</label>
          <input name="instagram_url" />
        </div>
        <div class="admin-field">
          <label>Facebook</label>
          <input name="facebook_url" />
        </div>
        <div class="admin-field">
          <label>TikTok</label>
          <input name="tiktok_url" />
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════
         SECCIÓN: HEADER & FOOTER
    ══════════════════════════════════════════════════ -->
    <section class="admin-panel cfg-section">
      <header class="cfg-section__header">
        <div class="cfg-section__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/>
          </svg>
        </div>
        <div>
          <h2 class="cfg-section__title">Header y footer</h2>
          <p class="admin-muted cfg-section__desc">Textos globales del encabezado y pie de página.</p>
        </div>
      </header>

      <div class="admin-field">
        <label>Texto barra superior header</label>
        <input name="header_top_text" />
      </div>
      <div class="admin-field" style="margin-top:14px">
        <label>Descripción footer</label>
        <textarea name="footer_brand_description"></textarea>
      </div>
    </section>

    <!-- Submit -->
    <div class="cfg-submit">
      <button class="btn btn--primary" type="submit">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
          <polyline points="17 21 17 13 7 13 7 21"/>
          <polyline points="7 3 7 8 15 8"/>
        </svg>
        Guardar configuración
      </button>
    </div>

  </form>
</AdminLayout>

<style>
.cfg-section {
  margin-bottom: 24px;
  padding: 28px 32px 32px;
}
.cfg-section__header {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  margin-bottom: 24px;
  padding-bottom: 20px;
  border-bottom: 1px solid rgba(90,62,43,.1);
}
.cfg-section__icon {
  width: 40px;
  height: 40px;
  min-width: 40px;
  background: rgba(90,62,43,.08);
  border-radius: 10px;
  display: grid;
  place-items: center;
  color: var(--color-earth);
  margin-top: 2px;
}
.cfg-section__title {
  font-family: var(--font-display, serif);
  font-size: 1.25rem;
  color: var(--color-earth);
  margin: 0 0 4px;
  font-weight: 700;
}
.cfg-section__desc {
  margin: 0;
  font-size: .85rem;
}

/* 5-column responsive grid for MediaPickers */
.cfg-media-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 20px;
}

.cfg-submit {
  display: flex;
  justify-content: flex-end;
  padding-top: 8px;
}
.cfg-submit .btn {
  display: flex;
  align-items: center;
  gap: 8px;
}

@media (max-width: 640px) {
  .cfg-section { padding: 20px 18px 24px; }
  .cfg-media-grid { grid-template-columns: 1fr; }
}
</style>

<script>
  import { adminSupabase, notify } from '@/lib/admin-client';

  const form = document.querySelector('#settingsForm') as HTMLFormElement | null;
  if (!form) throw new Error('Form not found');

  // All named inputs in the form (including hidden inputs from MediaPickers)
  const keys = [...(form as HTMLFormElement).elements]
    .filter((el: any) => el.name)
    .map((el: any) => el.name);

  function getFieldValue(name: string): string {
    const field = form?.querySelector(`[name="${name}"]`) as HTMLInputElement | null;
    return field?.value || '';
  }

  function setFieldValue(name: string, value = '') {
    const field = form?.querySelector(`[name="${name}"]`) as HTMLInputElement | null;
    if (!field) return;
    field.value = value;
    field.setAttribute('value', value);
    if (field.tagName === 'TEXTAREA') field.textContent = value;
    field.dispatchEvent(new Event('input',  { bubbles: true }));
    field.dispatchEvent(new Event('change', { bubbles: true }));
  }

  /** Broadcast all field values to every MediaPicker on the page */
  function updateMediaPickers(fields: Record<string, string>) {
    document.dispatchEvent(new CustomEvent('media-picker:update', { detail: { fields } }));
  }

  function settingType(key: string): string {
    if (key.includes('video')) return 'video';
    if (key.includes('image')) return 'image';
    return 'text';
  }

  // ── Load ──────────────────────────────────────────
  async function load() {
    const { data, error } = await adminSupabase
      .from('site_settings')
      .select('*')
      .in('setting_key', keys);

    if (error) return notify(error.message, 'error');

    const allFields: Record<string, string> = {};

    for (const row of data || []) {
      setFieldValue(row.setting_key, row.setting_value || '');
      allFields[row.setting_key] = row.setting_value || '';
    }

    // Pass ALL values so every MediaPicker (image & video) gets updated
    updateMediaPickers(allFields);
  }

  // ── Save ──────────────────────────────────────────
  form.addEventListener('submit', async (event) => {
    event.preventDefault();

    const rows = keys.map((key) => ({
      setting_key:   key,
      setting_value: getFieldValue(key),
      setting_type:  settingType(key),
      updated_at:    new Date().toISOString(),
    }));

    const { error } = await adminSupabase
      .from('site_settings')
      .upsert(rows, { onConflict: 'setting_key' });

    if (error) return notify(error.message, 'error');

    notify('Configuración guardada.', 'success');
    await load();
  });

  window.setTimeout(load, 250);
</script>
