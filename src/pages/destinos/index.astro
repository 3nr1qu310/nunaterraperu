---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Hero from '@/components/ui/Hero.astro';
import SectionHeading from '@/components/sections/SectionHeading.astro';
import DestinationCard from '@/components/cards/DestinationCard.astro';
import { getRegions, getDestinations } from '@/lib/content';
import './Destinos.scss';

const regions = await getRegions();
const destinations = await getDestinations();

const heroImage =
  regions.find((region) => region.slug === 'sierra')?.heroImage ||
  regions[0]?.heroImage ||
  '/images/destinations-hero.jpg';
---

<BaseLayout title="Destinos turísticos en Perú | Nuna Terra Perú">
  <Hero
    eyebrow="Costa, Sierra y Selva"
    title="Destinos que conectan con la esencia del Perú"
    subtitle="Explora la costa, sierra y selva a través de experiencias diseñadas para descubrir el país desde su alma, su cultura y su tierra."
    image={heroImage}
    primaryText="Explorar regiones"
    primaryHref="#regiones"
    secondaryText="Diseñar mi viaje"
    secondaryHref="/contacto"
  />

  <section class="section destinations-regions" id="regiones">
    <div class="container">
      <SectionHeading
        title="Explora Perú por regiones"
        subtitle="Descubre experiencias entre costa, sierra y selva, con rutas diseñadas según tu forma de viajar."
        centered
      />

      <div class="grid grid--3">
        {regions.map((region) => (
          <a class="region-link" href={`/destinos/${region.slug}`}>
            <img
              src={region.cardImage || region.heroImage || '/images/placeholders/destination-placeholder.jpg'}
              alt={region.name}
              loading="lazy"
            />

            <div class="region-link__content">
              <span>Región</span>
              <h3>{region.name}</h3>
              <p>{region.headline}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section destinations-list">
    <div class="container">
      <SectionHeading
        title="Todos los destinos"
        subtitle="Ciudades, paisajes y territorios para diseñar tu ruta por Perú."
      />

      <div class="grid grid--3">
        {destinations.map((destination) => (
          <DestinationCard destination={destination} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>