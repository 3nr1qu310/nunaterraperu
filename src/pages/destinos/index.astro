---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Hero from '@/components/ui/Hero.astro';
import SectionHeading from '@/components/sections/SectionHeading.astro';
import DestinationCard from '@/components/cards/DestinationCard.astro';
import { destinations } from '@/data/destinations';
import { regions } from '@/data/regions';
---
<BaseLayout title="Destinos turísticos en Perú | Nuna Terra Perú">
  <Hero eyebrow="Costa, Sierra y Selva" title="Destinos que conectan con la esencia del Perú" subtitle="Explora la costa, sierra y selva a través de experiencias diseñadas para descubrir el país desde su alma, su cultura y su tierra." image="/images/destinations-hero.jpg" primaryText="Explorar regiones" primaryHref="#regiones" secondaryText="Diseñar mi viaje" secondaryHref="/contacto" />
  <section class="section" id="regiones"><div class="container"><SectionHeading title="Explora Perú por regiones" centered /><div class="grid grid--3">{regions.map((r)=><a class="region-link" href={`/destinos/${r.slug}`}><img src={r.cardImage} alt={r.name}/><div><h3>{r.name}</h3><p>{r.headline}</p></div></a>)}</div></div></section>
  <section class="section"><div class="container"><SectionHeading title="Todos los destinos" subtitle="Ciudades, paisajes y territorios para diseñar tu ruta por Perú." /><div class="grid grid--3">{destinations.map((destination)=><DestinationCard destination={destination}/>)}</div></div></section>
</BaseLayout>
<style lang="scss">.region-link{min-height:360px;border-radius:var(--radius-lg);overflow:hidden;position:relative;display:grid;align-items:end;padding:26px;color:var(--color-ivory)}.region-link img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:600ms}.region-link::after{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(37,37,37,.78),transparent)}.region-link:hover img{transform:scale(1.08)}.region-link div{position:relative;z-index:1}.region-link h3{font-family:var(--font-display);font-size:3rem;margin:0}</style>
