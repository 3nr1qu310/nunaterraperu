---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Hero from '@/components/ui/Hero.astro';
import SectionHeading from '@/components/sections/SectionHeading.astro';
import DestinationCard from '@/components/cards/DestinationCard.astro';
import { getRegions, getDestinations } from '@/lib/content';
import './Destinos.scss';

export const prerender = false;

const regions = await getRegions();
const destinations = await getDestinations();

const heroImage =
  regions.find((region) => region.slug === 'sierra')?.heroImage ||
  regions[0]?.heroImage ||
  '/images/destinations-hero.jpg';
---

<BaseLayout title="Destinos turísticos en Perú | Nuna Terra Perú">
  <Hero
    eyebrow="Costa, Sierra y Selva"
    title="Destinos que conectan con la esencia del Perú"
    subtitle="Explora la costa, sierra y selva a través de experiencias diseñadas para descubrir el país desde su alma, su cultura y su tierra."
    image={heroImage}
    primaryText="Explorar regiones"
    primaryHref="#regiones"
    secondaryText="Diseñar mi viaje"
    secondaryHref="/contacto"
  />

  <section class="section destinations-regions" id="regiones">
    <div class="container">
      <div data-reveal>
        <SectionHeading
          title="Explora Perú por regiones"
          subtitle="Descubre experiencias entre costa, sierra y selva, con rutas diseñadas según tu forma de viajar."
          centered
          theme="dark"
        />
      </div>

      <div class="regions-grid">
        {regions.map((region, i) => (
          <a
            class="region-card"
            href={`/destinos/${region.slug}`}
            data-reveal
            style={`--stagger: ${i}`}
          >
            <img
              class="region-card__image"
              src={region.cardImage || region.heroImage || '/images/placeholders/destination-placeholder.jpg'}
              alt={region.name}
              loading="lazy"
            />
            <div class="region-card__overlay" aria-hidden="true"></div>
            <div class="region-card__content">
              <span class="region-card__eyebrow">Región</span>
              <h3 class="region-card__name">{region.name}</h3>
              <p class="region-card__desc">{region.headline}</p>
              <span class="region-card__cta" aria-hidden="true">
                Explorar
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section destinations-list">
    <div class="container">
      <div data-reveal>
        <SectionHeading
          title="Todos los destinos"
          subtitle="Ciudades, paisajes y territorios para diseñar tu ruta por Perú."
        />
      </div>

      <div class="destinations-bento">
        {destinations.map((destination, i) => (
          <div
            class="dest-bento-item"
            data-reveal
            style={`--stagger: ${i % 3}`}
          >
            <DestinationCard destination={destination} />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.1, rootMargin: '0px 0px -48px 0px' }
  );

  document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
</script>
