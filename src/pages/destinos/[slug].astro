---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import SectionHeading from '@/components/sections/SectionHeading.astro';
import ProductCard from '@/components/cards/ProductCard.astro';
import PlaceCard from '@/components/cards/PlaceCard.astro';

import {
  getDestinations,
  getDestinationBySlug,
  getProductsByDestinationSlug,
  getPlacesByDestinationSlug,
} from '@/lib/content';

import './DetalleDestino.scss';

export async function getStaticPaths() {
  const destinations = await getDestinations();
  return destinations.map((d) => ({ params: { slug: d.slug } }));
}

const slug = Astro.params.slug || '';

const destination = await getDestinationBySlug(slug);

if (!destination) {
  return Astro.redirect('/destinos');
}

const [relatedProducts, places] = await Promise.all([
  getProductsByDestinationSlug(slug),
  getPlacesByDestinationSlug(slug),
]);

const heroImage =
  destination.heroImage ||
  destination.cardImage ||
  '/images/placeholders/destination-placeholder.jpg';

const packages = relatedProducts.filter((p) => p.type === 'package');
const tours = relatedProducts.filter((p) => p.type === 'tour');

const featuredPlace = places[0];
const secondaryPlaces = places.slice(1);

const featuredPackage = packages[0];
const secondaryPackages = packages.slice(1);

const featuredTour = tours[0];
const secondaryTours = tours.slice(1);

const regionLabel =
  destination.region === 'costa'
    ? 'Costa'
    : destination.region === 'sierra'
      ? 'Sierra'
      : destination.region === 'selva'
        ? 'Selva'
        : destination.region;

const factItems = [
  { label: 'Región', value: regionLabel },
  ...(destination.altitude ? [{ label: 'Altitud', value: destination.altitude }] : []),
  ...(destination.bestTime ? [{ label: 'Mejor época', value: destination.bestTime }] : []),
  ...(destination.recommendedDays ? [{ label: 'Estadía sugerida', value: destination.recommendedDays }] : []),
];

const sectionLinks = [
  { href: '#overview', label: 'Resumen' },
  ...(places.length > 0 ? [{ href: '#lugares', label: 'Lugares' }] : []),
  ...(packages.length > 0 ? [{ href: '#paquetes', label: 'Paquetes' }] : []),
  ...(tours.length > 0 ? [{ href: '#tours', label: 'Tours' }] : []),
  { href: '#faqs', label: 'FAQ' },
];
---

<BaseLayout
  title={`${destination.name} | Nuna Terra Perú`}
  description={destination.description || destination.subtitle}
>
  <section class="destination-hero">
    <img
      src={heroImage}
      alt={destination.name}
      class="destination-hero__image"
      loading="eager"
      fetchpriority="high"
    />

    <div class="destination-hero__overlay"></div>
    <div class="destination-hero__grain" aria-hidden="true"></div>

    <div class="container destination-hero__grid">
      <div class="destination-hero__copy" data-reveal>
        <div class="destination-hero__topline">
          <span class="destination-hero__eyebrow">Destino del Perú</span>
          <span class="destination-hero__region">{regionLabel}</span>
        </div>

        <h1>{destination.name}</h1>

        <p class="destination-hero__lead">
          {destination.subtitle || destination.shortDescription || destination.description}
        </p>

        {destination.idealFor && destination.idealFor.length > 0 && (
          <div class="destination-hero__tags">
            {destination.idealFor.slice(0, 4).map((tag: string) => (
              <span>{tag}</span>
            ))}
          </div>
        )}

        <div class="destination-hero__actions">
          <a href="#paquetes" class="destination-btn destination-btn--primary">
            Ver experiencias
          </a>

          <a href="/contacto" class="destination-btn destination-btn--ghost">
            Diseñar mi viaje
          </a>
        </div>
      </div>

      <aside class="destination-hero__panel" data-reveal>
        <div class="destination-hero__panel-head">
          <span class="destination-hero__panel-kicker">Información esencial</span>
          <h2>{destination.name}</h2>
        </div>

        <div class="destination-hero__facts">
          {factItems.map((item) => (
            <div class="destination-hero__fact">
              <span class="destination-hero__fact-label">{item.label}</span>
              <span class="destination-hero__fact-value">{item.value}</span>
            </div>
          ))}
        </div>

        <p class="destination-hero__panel-text">
          Un destino pensado para viajeros que buscan contexto, autenticidad y una experiencia mejor organizada.
        </p>

        <a href="/contacto" class="destination-hero__panel-cta">
          Hablar con un asesor
        </a>
      </aside>
    </div>

    <div class="destination-hero__scroll" aria-hidden="true">
      <span></span>
      <small>Scroll</small>
    </div>
  </section>

  <nav class="destination-anchor-nav">
    <div class="container destination-anchor-nav__inner">
      {sectionLinks.map((item) => (
        <a href={item.href} class="destination-anchor-nav__link">{item.label}</a>
      ))}
    </div>
  </nav>

  <section class="destination-section destination-overview" id="overview">
    <div class="container destination-overview__grid">
      <div class="destination-overview__content" data-reveal>
        <SectionHeading
          eyebrow="Sobre este destino"
          title={`Descubre ${destination.name}`}
          align="left"
        />

        <div class="destination-overview__text">
          {destination.description
            ? destination.description.split('\n').filter(Boolean).map((para: string) => (
                <p>{para}</p>
              ))
            : (
                <p>{destination.shortDescription || destination.subtitle}</p>
              )}
        </div>
      </div>

      <aside class="destination-overview__card" data-reveal>
        <span class="destination-overview__card-eyebrow">Visión Nuna Terra</span>
        <h3>Una forma más cuidada de vivir {destination.name}</h3>
        <p>
          No se trata solo de visitar el destino, sino de entenderlo mejor, vivirlo con calma
          y conectarlo con una ruta coherente dentro del viaje.
        </p>

        {destination.idealFor && destination.idealFor.length > 0 && (
          <div class="destination-overview__chips">
            {destination.idealFor.map((tag: string) => (
              <span>{tag}</span>
            ))}
          </div>
        )}
      </aside>
    </div>
  </section>

  {(destination.altitude || destination.bestTime || destination.recommendedDays) && (
    <section class="destination-section destination-highlights">
      <div class="container">
        <div class="destination-highlights__grid" data-reveal-stagger>
          {destination.altitude && (
            <article class="destination-highlight-card">
              <span class="destination-highlight-card__label">Altitud</span>
              <strong>{destination.altitude}</strong>
              <p>Información útil para planificar mejor tu experiencia y ritmo de viaje.</p>
            </article>
          )}

          {destination.bestTime && (
            <article class="destination-highlight-card">
              <span class="destination-highlight-card__label">Mejor época</span>
              <strong>{destination.bestTime}</strong>
              <p>Una referencia clave para elegir el momento ideal según clima y experiencia.</p>
            </article>
          )}

          {destination.recommendedDays && (
            <article class="destination-highlight-card">
              <span class="destination-highlight-card__label">Tiempo sugerido</span>
              <strong>{destination.recommendedDays}</strong>
              <p>El tiempo recomendado para conocer el destino con mayor comodidad.</p>
            </article>
          )}
        </div>
      </div>
    </section>
  )}

  {places.length > 0 && (
    <section class="destination-section destination-showcase destination-showcase--places" id="lugares">
      <div class="container">
        <div class="destination-showcase__header" data-reveal>
          <div>
            <span class="destination-showcase__eyebrow">Lugares de interés</span>
            <h2>Qué visitar en {destination.name}</h2>
          </div>

          <p>
            Lugares emblemáticos dentro de este destino, cada uno con una historia,
            un paisaje y una forma distinta de vivir la experiencia.
          </p>
        </div>

        <div class="destination-showcase__layout destination-showcase__layout--places" data-reveal-stagger>
          {featuredPlace && (
            <div class="destination-showcase__featured">
              <PlaceCard place={featuredPlace} />
            </div>
          )}

          {secondaryPlaces.length > 0 && (
            <div class="destination-showcase__grid">
              {secondaryPlaces.map((place) => (
                <div class="destination-showcase__item">
                  <PlaceCard place={place} />
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  {packages.length > 0 && (
    <section class="destination-section destination-showcase destination-showcase--packages" id="paquetes">
      <div class="container">
        <div class="destination-showcase__header" data-reveal>
          <div>
            <span class="destination-showcase__eyebrow">Paquetes</span>
            <h2>Paquetes en {destination.name}</h2>
          </div>

          <p>
            Rutas completas diseñadas para vivir este destino con calma,
            buena organización y una experiencia mejor conectada.
          </p>
        </div>

        <div class="destination-showcase__layout destination-showcase__layout--products" data-reveal-stagger>
          {featuredPackage && (
            <div class="destination-showcase__featured destination-showcase__featured--product">
              <ProductCard product={featuredPackage} />
            </div>
          )}

          {secondaryPackages.length > 0 && (
            <div class="destination-showcase__grid destination-showcase__grid--products">
              {secondaryPackages.map((product) => (
                <div class="destination-showcase__item">
                  <ProductCard product={product} />
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  {tours.length > 0 && (
    <section class="destination-section destination-showcase destination-showcase--tours" id="tours">
      <div class="container">
        <div class="destination-showcase__header" data-reveal>
          <div>
            <span class="destination-showcase__eyebrow">Tours</span>
            <h2>Tours en {destination.name}</h2>
          </div>

          <p>
            Experiencias de uno o dos días para conocer lo esencial del destino
            con guía, logística y acompañamiento.
          </p>
        </div>

        <div class="destination-showcase__layout destination-showcase__layout--products destination-showcase__layout--reverse" data-reveal-stagger>
          {featuredTour && (
            <div class="destination-showcase__featured destination-showcase__featured--product">
              <ProductCard product={featuredTour} />
            </div>
          )}

          {secondaryTours.length > 0 && (
            <div class="destination-showcase__grid destination-showcase__grid--products">
              {secondaryTours.map((product) => (
                <div class="destination-showcase__item">
                  <ProductCard product={product} />
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <section class="destination-section destination-faqs" id="faqs">
    <div class="container destination-faqs__grid">
      <div class="destination-faqs__intro" data-reveal>
        <SectionHeading
          eyebrow="Preguntas frecuentes"
          title={`Lo que debes saber sobre ${destination.name}`}
          subtitle="Respuestas rápidas para ayudarte a tomar mejores decisiones antes de viajar."
          align="left"
        />
      </div>

      <div class="destination-faqs__list" data-reveal>
        <details open>
          <summary>¿Cuántos días se recomienda para visitar {destination.name}?</summary>
          <div class="faq-body"><div>
            <p>
              Depende del tipo de experiencia que quieras vivir. Si buscas algo más completo,
              lo ideal es integrarlo dentro de una ruta más amplia para disfrutarlo con mejor ritmo.
            </p>
          </div></div>
        </details>

        <details>
          <summary>¿Se puede combinar este destino con otros lugares del Perú?</summary>
          <div class="faq-body"><div>
            <p>
              Sí. Podemos integrarlo con otros destinos de costa, sierra o selva para diseñar
              una ruta coherente, cómoda y alineada a tus intereses.
            </p>
          </div></div>
        </details>

        <details>
          <summary>¿Es posible personalizar la experiencia?</summary>
          <div class="faq-body"><div>
            <p>
              Claro. En Nuna Terra Perú diseñamos experiencias a medida según tiempo disponible,
              estilo de viaje, nivel de confort y tipo de actividades que deseas priorizar.
            </p>
          </div></div>
        </details>
      </div>
    </div>
  </section>

  <section class="destination-final-cta">
    <div class="container destination-final-cta__inner" data-reveal>
      <span class="destination-final-cta__eyebrow">Diseña tu experiencia</span>
      <h2>¿Quieres incluir {destination.name} en tu próxima ruta por Perú?</h2>
      <p>
        Creamos una experiencia a medida para integrar este destino dentro de una ruta clara,
        elegante y memorable.
      </p>

      <div class="destination-final-cta__actions">
        <a href="/contacto" class="destination-btn destination-btn--primary">
          Comenzar a planear
        </a>
        <a href="/contacto" class="destination-btn destination-btn--ghost-dark">
          Hablar con un asesor
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const prefersMotion = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;

  const revealObs = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObs.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('[data-reveal]').forEach((el) => revealObs.observe(el));

  const staggerObs = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const children = Array.from(entry.target.children);
          children.forEach((child, i) => (child as HTMLElement).style.setProperty('--si', String(i)));
          entry.target.classList.add('is-visible');
          staggerObs.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.08, rootMargin: '0px 0px -36px 0px' }
  );

  document.querySelectorAll('[data-reveal-stagger]').forEach((el) => staggerObs.observe(el));

  const heroImg = document.querySelector('.destination-hero__image') as HTMLElement | null;

  if (heroImg && prefersMotion) {
    let raf = 0;

    window.addEventListener(
      'scroll',
      () => {
        cancelAnimationFrame(raf);

        raf = requestAnimationFrame(() => {
          const y = window.scrollY;
          if (y < window.innerHeight * 1.3) {
            heroImg.style.transform = `scale(1.06) translateY(${y * 0.12}px)`;
          }
        });
      },
      { passive: true }
    );
  }

  document.querySelectorAll('.destination-faqs details').forEach((det) => {
    const summary = det.querySelector('summary');
    if (!summary) return;

    summary.addEventListener('click', (e) => {
      e.preventDefault();
      (det as HTMLDetailsElement).open = !(det as HTMLDetailsElement).open;
    });
  });
</script>