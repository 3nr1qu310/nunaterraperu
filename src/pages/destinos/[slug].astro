---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import SectionHeading from '@/components/sections/SectionHeading.astro';
import ProductCard from '@/components/cards/ProductCard.astro';

import {
  getDestinationBySlug,
  getProductsByDestinationSlug,
} from '@/lib/content';

import './DetalleDestino.scss';

const slug = Astro.params.slug || '';

const destination = await getDestinationBySlug(slug);

if (!destination) {
  return Astro.redirect('/destinos');
}

const relatedProducts = await getProductsByDestinationSlug(slug);

const heroImage =
  destination.heroImage ||
  destination.cardImage ||
  '/images/placeholders/destination-placeholder.jpg';

const packages = relatedProducts.filter((p) => p.type === 'package');
const tours = relatedProducts.filter((p) => p.type === 'tour');
---

<BaseLayout
  title={`${destination.name} | Nuna Terra Perú`}
  description={destination.description || destination.subtitle}
>
  <section class="destination-hero">
    <img
      src={heroImage}
      alt={destination.name}
      class="destination-hero__image"
      loading="eager"
      fetchpriority="high"
    />

    <div class="destination-hero__overlay"></div>

    <div class="container destination-hero__content">
      <p class="destination-hero__eyebrow">
        Destino en la {destination.region} del Perú
      </p>

      <h1>{destination.name}</h1>

      <p>{destination.subtitle || destination.description}</p>

      <div class="destination-hero__actions">
        <a href="#experiencias" class="destination-btn destination-btn--primary">
          Ver experiencias
        </a>

        <a href="/contacto" class="destination-btn destination-btn--ghost">
          Diseñar mi viaje
        </a>
      </div>
    </div>
  </section>

  <section class="destination-section destination-info">
    <div class="container destination-info__grid">
      <div>
        <SectionHeading
          eyebrow="Destino destacado"
          title={`Descubre ${destination.name}`}
          subtitle={destination.description}
          align="left"
        />

        <p class="destination-info__lead">
          Cada destino tiene una historia. En Nuna Terra Perú lo convertimos en una experiencia organizada,
          clara y memorable.
        </p>
      </div>

      <aside class="destination-info-card">
        <h3>Información útil</h3>

        <p><b>Región:</b> {destination.region}</p>
        {destination.altitude && <p><b>Altitud:</b> {destination.altitude}</p>}
        {destination.bestTime && <p><b>Mejor época:</b> {destination.bestTime}</p>}
        {destination.recommendedDays && <p><b>Duración sugerida:</b> {destination.recommendedDays}</p>}
      </aside>
    </div>
  </section>

  {packages.length > 0 && (
    <section class="destination-section destination-products" id="experiencias">
      <div class="container">
        <SectionHeading
          eyebrow="Paquetes"
          title={`Paquetes en ${destination.name}`}
          subtitle="Rutas completas diseñadas para vivir este destino con calma y organización."
          align="left"
        />
        <div class="dest-scroll">
          {packages.map((product) => (
            <div class="dest-scroll__item">
              <ProductCard product={product} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {tours.length > 0 && (
    <section class="destination-section destination-products--alt">
      <div class="container">
        <SectionHeading
          eyebrow="Tours"
          title={`Tours en ${destination.name}`}
          subtitle="Experiencias de uno o dos días para descubrir este destino con guía y acompañamiento."
          align="left"
        />
        <div class="dest-scroll">
          {tours.map((product) => (
            <div class="dest-scroll__item">
              <ProductCard product={product} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="destination-section destination-faqs">
    <div class="container">
      <SectionHeading
        title={`Preguntas frecuentes sobre ${destination.name}`}
        centered
      />

      <div class="destination-faqs__list">
        <details>
          <summary>¿Cuántos días se recomienda?</summary>
          <p>Depende de tu ruta, pero podemos adaptar la experiencia a tus fechas e intereses.</p>
        </details>

        <details>
          <summary>¿Puedo incluir este destino en una ruta personalizada?</summary>
          <p>Sí. Diseñamos rutas a medida por costa, sierra y selva del Perú.</p>
        </details>
      </div>
    </div>
  </section>

  <section class="destination-final-cta">
    <div class="container destination-final-cta__inner">
      <h2>¿Quieres incluir {destination.name} en tu próxima ruta por Perú?</h2>
      <p>Creamos una experiencia a medida para integrar este destino en una ruta clara, cómoda y memorable.</p>

      <div>
        <a href="/contacto" class="destination-btn destination-btn--primary">
          Comenzar a planear
        </a>

        <a href="/contacto" class="destination-btn destination-btn--ghost">
          Hablar con un asesor
        </a>
      </div>
    </div>
  </section>
</BaseLayout>