---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import SectionHeading from '@/components/sections/SectionHeading.astro';
import ProductCard from '@/components/cards/ProductCard.astro';
import PlaceCard from '@/components/cards/PlaceCard.astro';

import {
  getDestinations,
  getDestinationBySlug,
  getProductsByDestinationSlug,
  getPlacesByDestinationSlug,
  getTravelCategories,
} from '@/lib/content';

import './DetalleDestino.scss';

export async function getStaticPaths() {
  const destinations = await getDestinations();

  return destinations.map((destination) => ({
    params: {
      slug: destination.slug,
    },
  }));
}

const slug = Astro.params.slug || '';

const destination = await getDestinationBySlug(slug);

if (!destination) {
  return Astro.redirect('/destinos');
}

const [relatedProducts, places, allTravelCategories] = await Promise.all([
  getProductsByDestinationSlug(slug),
  getPlacesByDestinationSlug(slug),
  getTravelCategories(),
]);

const heroImage =
  destination.heroImage ||
  destination.cardImage ||
  '/images/placeholders/destination-placeholder.jpg';

const packages = relatedProducts.filter((product) => product.type === 'package');
const tours = relatedProducts.filter((product) => product.type === 'tour');

const regionLabel =
  destination.region === 'costa'
    ? 'Costa'
    : destination.region === 'sierra'
      ? 'Sierra'
      : destination.region === 'selva'
        ? 'Selva'
        : destination.region;

const factItems = [
  { label: 'Región', value: regionLabel },
  ...(destination.altitude ? [{ label: 'Altitud', value: destination.altitude }] : []),
  ...(destination.bestTime ? [{ label: 'Mejor época', value: destination.bestTime }] : []),
  ...(destination.recommendedDays ? [{ label: 'Estadía sugerida', value: destination.recommendedDays }] : []),
];

const unique = <T,>(items: T[]) => [...new Set(items.filter(Boolean))];

const relatedCategorySlugs = unique(
  relatedProducts.flatMap((product) => product.categorySlugs || [])
);

const relatedTravelStyles = allTravelCategories
  .filter((category) => relatedCategorySlugs.includes(category.slug))
  .map((category) => {
    const matchingProducts = relatedProducts.filter((product) =>
      product.categorySlugs?.includes(category.slug)
    );

    const firstProduct = matchingProducts[0];

    return {
      ...category,
      count: matchingProducts.length,
      image:
        category.cardImage ||
        category.heroImage ||
        firstProduct?.cardImage ||
        firstProduct?.heroImage ||
        heroImage,
    };
  })
  .slice(0, 8);

const galleryItemsRaw = [
  {
    imageUrl: destination.heroImage,
    altText: destination.name,
    caption: destination.name,
    type: 'Destino',
  },
  {
    imageUrl: destination.cardImage,
    altText: destination.name,
    caption: destination.subtitle || destination.name,
    type: 'Destino',
  },
  ...places.flatMap((place) => [
    {
      imageUrl: place.heroImage,
      altText: place.name,
      caption: place.name,
      type: 'Lugar',
    },
    {
      imageUrl: place.cardImage,
      altText: place.name,
      caption: place.subtitle || place.name,
      type: 'Lugar',
    },
  ]),
  ...relatedProducts.flatMap((product) => [
    {
      imageUrl: product.heroImage,
      altText: product.title,
      caption: product.title,
      type: product.type === 'package' ? 'Paquete' : 'Tour',
    },
    {
      imageUrl: product.cardImage,
      altText: product.title,
      caption: product.subtitle || product.title,
      type: product.type === 'package' ? 'Paquete' : 'Tour',
    },
    ...((product.gallery || []).map((image) => ({
      imageUrl: image.imageUrl,
      altText: image.altText || product.title,
      caption: image.caption || product.title,
      type: product.type === 'package' ? 'Paquete' : 'Tour',
    }))),
  ]),
];

const seenImages = new Set<string>();

const galleryItems = galleryItemsRaw
  .filter((item) => {
    if (!item.imageUrl) return false;
    if (seenImages.has(item.imageUrl)) return false;

    seenImages.add(item.imageUrl);
    return true;
  })
  .slice(0, 9);

const sectionLinks = [
  { href: '#overview', label: 'Resumen' },
  ...(relatedTravelStyles.length > 0 ? [{ href: '#estilos', label: 'Estilos' }] : []),
  ...(galleryItems.length > 2 ? [{ href: '#galeria', label: 'Galería' }] : []),
  ...(places.length > 0 ? [{ href: '#lugares', label: 'Lugares' }] : []),
  ...(packages.length > 0 ? [{ href: '#paquetes', label: 'Paquetes' }] : []),
  ...(tours.length > 0 ? [{ href: '#tours', label: 'Tours' }] : []),
  { href: '#faqs', label: 'FAQ' },
];
---

<BaseLayout
  title={`${destination.name} | Nuna Terra Perú`}
  description={destination.description || destination.subtitle}
>
  <section class="destination-hero">
    <img
      src={heroImage}
      alt={destination.name}
      class="destination-hero__image"
      loading="eager"
      fetchpriority="high"
    />

    <div class="destination-hero__overlay"></div>
    <div class="destination-hero__grain" aria-hidden="true"></div>

    <div class="container destination-hero__copy" data-reveal>
      <div class="destination-hero__topline">
        <span class="destination-hero__eyebrow">Destino del Perú</span>
        <span class="destination-hero__region">{regionLabel}</span>
      </div>

      <h1>{destination.name}</h1>

      <p class="destination-hero__lead">
        {destination.subtitle || destination.shortDescription || destination.description}
      </p>

      {destination.idealFor && destination.idealFor.length > 0 && (
        <div class="destination-hero__tags">
          {destination.idealFor.slice(0, 4).map((tag: string) => (
            <span>{tag}</span>
          ))}
        </div>
      )}

      <div class="destination-hero__actions">
        <a href={packages.length > 0 ? '#paquetes' : '#tours'} class="destination-btn destination-btn--primary">
          Ver experiencias
        </a>

        <a href="/contacto" class="destination-btn destination-btn--ghost">
          Hablar con un asesor
        </a>
      </div>
    </div>

    {factItems.length > 0 && (
      <div class="destination-hero__facts-strip" data-reveal>
        <div class="container destination-hero__facts-inner">
          {factItems.map((item) => (
            <div class="destination-hero__fact">
              <span class="destination-hero__fact-label">{item.label}</span>
              <span class="destination-hero__fact-value">{item.value}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="destination-hero__scroll" aria-hidden="true">
      <span></span>
      <small>Scroll</small>
    </div>
  </section>

  <nav class="destination-anchor-nav">
    <div class="container destination-anchor-nav__inner">
      {sectionLinks.map((item) => (
        <a href={item.href} class="destination-anchor-nav__link">{item.label}</a>
      ))}
    </div>
  </nav>

  <section class="destination-section destination-overview" id="overview">
    <div class="container destination-overview__grid">
      <div class="destination-overview__content" data-reveal>
        <SectionHeading
          eyebrow="Sobre este destino"
          title={`Descubre ${destination.name}`}
          align="left"
        />

        <div class="destination-overview__text">
          {destination.description
            ? destination.description.split('\n').filter(Boolean).map((para: string) => (
                <p>{para}</p>
              ))
            : (
                <p>{destination.shortDescription || destination.subtitle}</p>
              )}
        </div>
      </div>

      <aside class="destination-overview__manifesto" data-reveal>
        <span class="destination-overview__manifesto-kicker">Visión Nuna Terra</span>
        <h3 class="destination-overview__manifesto-title">
          Una forma más cuidada de vivir {destination.name}
        </h3>
        <p>
          No se trata solo de visitar el destino: es entenderlo, vivirlo con calma
          y conectarlo con coherencia dentro de la ruta completa.
        </p>

        {destination.idealFor && destination.idealFor.length > 0 && (
          <div class="destination-overview__chips">
            {destination.idealFor.map((tag: string) => (
              <span>{tag}</span>
            ))}
          </div>
        )}

        <a href="/contacto" class="destination-overview__manifesto-cta">
          Diseñar mi viaje →
        </a>
      </aside>
    </div>
  </section>

  {(destination.altitude || destination.bestTime || destination.recommendedDays) && (
    <section class="destination-highlights">
      <div class="container">
        <div class="destination-highlights__bar" data-reveal-stagger>
          {destination.altitude && (
            <article class="destination-highlight-stat">
              <span class="destination-highlight-stat__label">Altitud</span>
              <strong>{destination.altitude}</strong>
              <p>Dato clave para planificar mejor el ritmo del viaje.</p>
            </article>
          )}

          {destination.bestTime && (
            <article class="destination-highlight-stat">
              <span class="destination-highlight-stat__label">Mejor época</span>
              <strong>{destination.bestTime}</strong>
              <p>Una referencia útil para elegir el mejor momento de visita.</p>
            </article>
          )}

          {destination.recommendedDays && (
            <article class="destination-highlight-stat">
              <span class="destination-highlight-stat__label">Tiempo sugerido</span>
              <strong>{destination.recommendedDays}</strong>
              <p>Tiempo recomendado para disfrutarlo con más comodidad.</p>
            </article>
          )}
        </div>
      </div>
    </section>
  )}

  {relatedTravelStyles.length > 0 && (
    <section class="destination-section destination-styles" id="estilos">
      <div class="container">
        <div class="destination-styles__header" data-reveal>
          <span class="destination-styles__eyebrow">Estilos de viaje</span>
          <h2>Formas de vivir {destination.name}</h2>
          <p>
            Cada destino puede sentirse diferente según el tipo de experiencia que buscas:
            cultura, naturaleza, aventura, familia o una ruta más premium.
          </p>
        </div>

        <div class="destination-styles__grid" data-reveal-stagger>
          {relatedTravelStyles.map((style) => (
            <a href={`/categorias/${style.slug}`} class="destination-style-card">
              <img src={style.image} alt={style.name} loading="lazy" />
              <span class="destination-style-card__shade"></span>

              <div class="destination-style-card__body">
                {style.icon && <span class="destination-style-card__icon">{style.icon}</span>}
                <span class="destination-style-card__label">Estilo de viaje</span>
                <h3>{style.name}</h3>
                {style.description && <p>{style.description}</p>}
                <small>{style.count} experiencia{style.count === 1 ? '' : 's'} relacionada{style.count === 1 ? '' : 's'}</small>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {galleryItems.length > 2 && (
    <section class="destination-section destination-gallery" id="galeria">
      <div class="container">
        <div class="destination-gallery__header" data-reveal>
          <div>
            <span class="destination-gallery__eyebrow">Galería</span>
            <h2>Una mirada visual a {destination.name}</h2>
          </div>

          <p>
            Imágenes tomadas de los lugares, paquetes y tours relacionados con este destino.
          </p>
        </div>

        <div class="destination-gallery__grid" data-reveal-stagger>
          {galleryItems.map((item, index) => (
            <figure class={`destination-gallery__item ${index === 0 ? 'is-large' : ''} ${index === 3 ? 'is-wide' : ''}`}>
              <img src={item.imageUrl} alt={item.altText || item.caption || destination.name} loading="lazy" />
              <figcaption>
                <span>{item.type}</span>
                <strong>{item.caption || destination.name}</strong>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  {places.length > 0 && (
    <section class="destination-section destination-curated destination-curated--places" id="lugares">
      <div class="container">
        <div class="destination-curated__top" data-reveal>
          <div class="destination-curated__intro">
            <span class="destination-curated__eyebrow">Lugares de interés</span>
            <h2>Qué visitar en {destination.name}</h2>
            <p>
              Una selección de espacios emblemáticos para entender el destino desde su historia,
              paisaje y forma de vida.
            </p>
          </div>

          <div class="destination-curated__actions">
            <button class="destination-curated__arrow" type="button" data-carousel-prev="places" aria-label="Ver lugares anteriores">←</button>
            <button class="destination-curated__arrow" type="button" data-carousel-next="places" aria-label="Ver más lugares">→</button>
          </div>
        </div>

        <div class="destination-carousel destination-carousel--places" data-carousel="places" data-reveal>
          <div class="destination-carousel__viewport">
            <div class="destination-carousel__track" data-carousel-track>
              {places.map((place, index) => (
                <article class={`destination-carousel__slide destination-carousel__slide--place ${index === 0 ? 'is-featured' : ''}`}>
                  <PlaceCard place={place} />
                </article>
              ))}
            </div>
          </div>

          <div class="destination-carousel__hint">
            <span>Desliza para explorar</span>
          </div>
        </div>
      </div>
    </section>
  )}

  {packages.length > 0 && (
    <section class="destination-section destination-curated destination-curated--packages" id="paquetes">
      <div class="container">
        <div class="destination-curated__split">
          <div class="destination-curated__sticky-copy" data-reveal>
            <span class="destination-curated__eyebrow">Paquetes</span>
            <h2>Paquetes en {destination.name}</h2>
            <p>
              Rutas completas para vivir este destino con una estructura clara:
              tiempos bien pensados, experiencias conectadas y acompañamiento real.
            </p>

            <div class="destination-curated__mini-stats">
              <span>{packages.length} opciones disponibles</span>
              <span>Rutas organizadas</span>
            </div>

            <div class="destination-curated__actions destination-curated__actions--left">
              <button class="destination-curated__arrow" type="button" data-carousel-prev="packages" aria-label="Ver paquetes anteriores">←</button>
              <button class="destination-curated__arrow" type="button" data-carousel-next="packages" aria-label="Ver más paquetes">→</button>
            </div>
          </div>

          <div class="destination-carousel destination-carousel--products" data-carousel="packages" data-reveal>
            <div class="destination-carousel__viewport">
              <div class="destination-carousel__track" data-carousel-track>
                {packages.map((product, index) => (
                  <article class={`destination-carousel__slide destination-carousel__slide--product ${index === 0 ? 'is-featured' : ''}`}>
                    <ProductCard product={product} />
                  </article>
                ))}
              </div>
            </div>

            <div class="destination-carousel__hint">
              <span>Explora los paquetes</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  {tours.length > 0 && (
    <section class="destination-section destination-curated destination-curated--tours" id="tours">
      <div class="container">
        <div class="destination-curated__top destination-curated__top--dark" data-reveal>
          <div class="destination-curated__intro">
            <span class="destination-curated__eyebrow">Tours</span>
            <h2>Tours en {destination.name}</h2>
            <p>
              Experiencias más puntuales para descubrir lo esencial del destino en menos tiempo,
              con guía, logística y una ruta bien resuelta.
            </p>
          </div>

          <div class="destination-curated__actions">
            <button class="destination-curated__arrow" type="button" data-carousel-prev="tours" aria-label="Ver tours anteriores">←</button>
            <button class="destination-curated__arrow" type="button" data-carousel-next="tours" aria-label="Ver más tours">→</button>
          </div>
        </div>

        <div class="destination-carousel destination-carousel--tours" data-carousel="tours" data-reveal>
          <div class="destination-carousel__viewport">
            <div class="destination-carousel__track" data-carousel-track>
              {tours.map((product, index) => (
                <article class={`destination-carousel__slide destination-carousel__slide--tour ${index === 0 ? 'is-featured' : ''}`}>
                  <ProductCard product={product} />
                </article>
              ))}
            </div>
          </div>

          <div class="destination-carousel__hint">
            <span>Desliza para ver más tours</span>
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="destination-section destination-faqs" id="faqs">
    <div class="container destination-faqs__grid">
      <div class="destination-faqs__intro" data-reveal>
        <SectionHeading
          eyebrow="Preguntas frecuentes"
          title={`Lo que debes saber sobre ${destination.name}`}
          subtitle="Respuestas rápidas para ayudarte a tomar mejores decisiones antes de viajar."
          align="left"
        />

        {destination.idealFor && destination.idealFor.length > 0 && (
          <div class="destination-faqs__tags">
            <span class="destination-faqs__tags-label">Ideal para</span>
            <div class="destination-faqs__tags-list">
              {destination.idealFor.map((tag: string) => (
                <span>{tag}</span>
              ))}
            </div>
          </div>
        )}

        <a href="/contacto" class="destination-faqs__cta">
          Diseñar mi viaje
        </a>
      </div>

      <div class="destination-faqs__list" data-reveal>
        <details open>
          <summary>¿Cuántos días se recomienda para visitar {destination.name}?</summary>
          <div class="faq-body"><div>
            <p>
              Depende del tipo de experiencia que quieras vivir. Si buscas algo más completo,
              lo ideal es integrarlo dentro de una ruta más amplia para disfrutarlo con mejor ritmo.
            </p>
          </div></div>
        </details>

        <details>
          <summary>¿Se puede combinar este destino con otros lugares del Perú?</summary>
          <div class="faq-body"><div>
            <p>
              Sí. Podemos integrarlo con otros destinos de costa, sierra o selva para diseñar
              una ruta coherente, cómoda y alineada a tus intereses.
            </p>
          </div></div>
        </details>

        <details>
          <summary>¿Es posible personalizar la experiencia?</summary>
          <div class="faq-body"><div>
            <p>
              Claro. En Nuna Terra Perú diseñamos experiencias a medida según tiempo disponible,
              estilo de viaje, nivel de confort y tipo de actividades que deseas priorizar.
            </p>
          </div></div>
        </details>
      </div>
    </div>
  </section>

  <section class="destination-final-cta">
    <div class="container destination-final-cta__inner" data-reveal>
      <div class="destination-final-cta__left">
        <span class="destination-final-cta__eyebrow">Diseña tu experiencia</span>
        <h2>¿Quieres incluir {destination.name} en tu próxima ruta por Perú?</h2>
      </div>

      <div class="destination-final-cta__right">
        <p>
          Creamos una experiencia a medida para integrar este destino dentro de una ruta clara,
          elegante y memorable.
        </p>

        <div class="destination-final-cta__actions">
          <a href="/contacto" class="destination-btn destination-btn--primary">
            Comenzar a planear
          </a>
          <a href="/contacto" class="destination-btn destination-btn--ghost-dark">
            Hablar con un asesor
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const prefersMotion = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;

  const revealObs = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObs.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('[data-reveal]').forEach((el) => revealObs.observe(el));

  const staggerObs = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const children = Array.from(entry.target.children);
          children.forEach((child, i) => (child as HTMLElement).style.setProperty('--si', String(i)));
          entry.target.classList.add('is-visible');
          staggerObs.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.08, rootMargin: '0px 0px -36px 0px' }
  );

  document.querySelectorAll('[data-reveal-stagger]').forEach((el) => staggerObs.observe(el));

  const heroImg = document.querySelector('.destination-hero__image') as HTMLElement | null;

  if (heroImg && prefersMotion) {
    let raf = 0;

    window.addEventListener(
      'scroll',
      () => {
        cancelAnimationFrame(raf);

        raf = requestAnimationFrame(() => {
          const y = window.scrollY;
          if (y < window.innerHeight * 1.3) {
            heroImg.style.transform = `scale(1.06) translateY(${y * 0.12}px)`;
          }
        });
      },
      { passive: true }
    );
  }

  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.destination-anchor-nav__link');

  if (navLinks.length > 0) {
    const anchorObs = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            navLinks.forEach((link) => {
              link.classList.toggle('is-active', link.getAttribute('href') === `#${entry.target.id}`);
            });
          }
        }
      },
      { threshold: 0.25, rootMargin: '-96px 0px -55% 0px' }
    );

    document.querySelectorAll<HTMLElement>('[id]').forEach((sec) => {
      if ([...navLinks].some((link) => link.getAttribute('href') === `#${sec.id}`)) {
        anchorObs.observe(sec);
      }
    });
  }

  document.querySelectorAll('.destination-faqs details').forEach((det) => {
    const summary = det.querySelector('summary');
    if (!summary) return;

    summary.addEventListener('click', (e) => {
      e.preventDefault();
      (det as HTMLDetailsElement).open = !(det as HTMLDetailsElement).open;
    });
  });

  const carousels = document.querySelectorAll<HTMLElement>('[data-carousel]');

  carousels.forEach((carousel) => {
    const name = carousel.dataset.carousel;
    const track = carousel.querySelector<HTMLElement>('[data-carousel-track]');
    const prev = document.querySelector<HTMLButtonElement>(`[data-carousel-prev="${name}"]`);
    const next = document.querySelector<HTMLButtonElement>(`[data-carousel-next="${name}"]`);

    if (!track || !name) return;

    const getStep = () => {
      const firstSlide = track.querySelector<HTMLElement>('.destination-carousel__slide');
      if (!firstSlide) return 320;

      const styles = window.getComputedStyle(track);
      const gap = Number.parseFloat(styles.columnGap || styles.gap || '18');

      return firstSlide.offsetWidth + gap;
    };

    const updateButtons = () => {
      if (!prev || !next) return;

      const maxScroll = track.scrollWidth - track.clientWidth;
      const current = track.scrollLeft;

      prev.disabled = current <= 4;
      next.disabled = current >= maxScroll - 4;
    };

    prev?.addEventListener('click', () => {
      track.scrollBy({
        left: -getStep(),
        behavior: 'smooth',
      });
    });

    next?.addEventListener('click', () => {
      track.scrollBy({
        left: getStep(),
        behavior: 'smooth',
      });
    });

    track.addEventListener('scroll', updateButtons, { passive: true });
    window.addEventListener('resize', updateButtons);

    updateButtons();
  });
</script>