---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import ProductCard from '@/components/cards/ProductCard.astro';
import LucideIcon from '@/components/cards/LucideIcon.astro';
import { getPackages, getTravelCategories } from '@/lib/content';
import { getSiteSettings } from '@/lib/settings';
import { site } from '@/lib/site';
import './PackageIndex.scss';

export const prerender = false;

const [allPackages, allCategories, settings] = await Promise.all([
  getPackages(),
  getTravelCategories(),
  getSiteSettings(['paquetes_hero_video']),
]);

const paquetesHeroVideo = settings['paquetes_hero_video'] || '';

/* ── Hero con imágenes reales de los paquetes ── */
const featuredHeroPackage =
  allPackages.find((pkg) => pkg.featured) || allPackages[0] || null;

const heroImage =
  featuredHeroPackage?.heroImage ||
  featuredHeroPackage?.cardImage ||
  '/images/packages-hero.jpg';

const customCtaImage =
  allPackages[1]?.heroImage || heroImage;

/* ── Robust category matching (by slug AND by name) ── */
function normalizeStr(s: string): string {
  return s.toLowerCase().normalize('NFD').replace(/\p{Diacritic}/gu, '').trim();
}

const activeCategorySlugs = new Set(allPackages.flatMap((p) => p.categorySlugs || []));
const activeCategories = allCategories.filter((cat) =>
  activeCategorySlugs.has(cat.slug)
);

const uniqueDestinations = new Set(allPackages.flatMap((p) => p.destinations || []));

/* ── Marquee ── */
const baseMarquee =
  uniqueDestinations.size >= 5
    ? Array.from(uniqueDestinations)
    : ['Cusco', 'Machu Picchu', 'Lago Titicaca', 'Arequipa', 'Lima', 'Nazca', 'Iquitos', 'Valle Sagrado', 'Cañón del Colca', 'Huaraz', 'Paracas', 'Trujillo'];
const marqueeItems = [...baseMarquee, ...baseMarquee];
const marqueeDuration = `${Math.max(32, baseMarquee.length * 4)}s`;

/* ── Category groups (catalog) ── */
const categoryGroups = activeCategories
  .map((cat) => ({
    ...cat,
    packages: allPackages.filter((pkg) => {
      const slugMatch = pkg.categorySlugs?.some(
        (s) => normalizeStr(s) === normalizeStr(cat.slug)
      );
      const nameMatch = (pkg as { categories?: string[] }).categories?.some(
        (c) => normalizeStr(c) === normalizeStr(cat.name)
      );
      return slugMatch || nameMatch;
    }),
  }))
  .filter((g) => g.packages.length > 0);

/* ── Process steps ── */
const steps = [
  {
    num: '01',
    icon: 'search',
    title: 'Descubre tu itinerario',
    description: 'Explora el catálogo por estilo de viaje y duración. Desde circuitos de 4 noches hasta expediciones de dos semanas.',
  },
  {
    num: '02',
    icon: 'message-circle',
    title: 'Coordina los detalles',
    description: 'Un asesor de Nuna Terra te responde en menos de 24 h para confirmar fechas, ajustar el grupo y personalizar paradas.',
  },
  {
    num: '03',
    icon: 'map',
    title: 'Vive el viaje',
    description: 'Guías locales, alojamientos cuidados y logística completa. Tú solo disfruta — nosotros nos encargamos del resto.',
  },
];

/* ── Trust items ── */
const trustItems = [
  {
    icon: 'compass',
    title: 'Itinerarios con alma',
    description: 'No armamos paquetes genéricos. Cada ruta fue diseñada por alguien que conoce el destino de primera mano, con paradas que no aparecen en ninguna guía.',
  },
  {
    icon: 'shield',
    title: 'Precio todo incluido',
    description: 'Transporte, alojamiento, guía y entradas: todo está detallado antes de reservar. Sin cargos sorpresa al llegar al destino.',
  },
  {
    icon: 'users',
    title: 'Grupos reducidos',
    description: 'Máximo 12 personas por salida. Viajes más personales, más flexibles y con mayor acceso a experiencias fuera de ruta.',
  },
  {
    icon: 'clock',
    title: 'Logística sin estrés',
    description: 'Coordinamos traslados, hospedajes y permisos especiales. Si algo cambia en ruta, nuestro equipo lo resuelve en el momento.',
  },
];
---

<BaseLayout
  title="Paquetes turísticos por Perú | Nuna Terra Perú"
  description="Itinerarios de varios días para descubrir la costa, sierra y selva del Perú con guías, alojamiento y logística incluidos."
>

  <!-- ══════════════════════════════════════════════════════════
       HERO — full-bleed, cinematic
  ══════════════════════════════════════════════════════════ -->
  <section class="pri-hero" aria-label="Paquetes turísticos por el Perú">
    {paquetesHeroVideo ? (
      <video
        class="pri-hero__bg"
        data-deferred-video={paquetesHeroVideo}
        preload="none"
        muted
        loop
        playsinline
        poster={heroImage}
      />
    ) : (
      <img
        class="pri-hero__bg"
        src={heroImage}
        alt={featuredHeroPackage?.title || 'Paquetes turísticos por el Perú'}
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    )}
    <div class="pri-hero__overlay" aria-hidden="true"></div>

    <div class="container pri-hero__content">
      <p class="pri-hero__eyebrow">
        <span class="pri-hero__dot" aria-hidden="true"></span>
        Paquetes turísticos
      </p>

      <h1 class="pri-hero__title">
        El Perú en<br /><em>profundidad</em>
      </h1>

      <p class="pri-hero__subtitle">
        Itinerarios de varios días con alojamiento, guía local y logística completa.
        Para quienes quieren ir más allá de la superficie.
      </p>

      <div class="pri-hero__actions">
        <a href="#catalogo" class="pri-hero__btn pri-hero__btn--primary">
          Ver paquetes
        </a>
        <a
          href={site.whatsappUrl}
          class="pri-hero__btn pri-hero__btn--ghost"
          target="_blank"
          rel="noopener noreferrer"
        >
          Consultar por WhatsApp ↗
        </a>
      </div>
    </div>

    <div class="pri-hero__scroll" aria-hidden="true">
      <span class="pri-hero__scroll-line"></span>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       MARQUEE — destination ticker
  ══════════════════════════════════════════════════════════ -->
  <div class="pri-marquee" aria-hidden="true">
    <div class="pri-marquee__track" style={`--duration: ${marqueeDuration}`}>
      {marqueeItems.map((dest) => (
        <>
          <span class="pri-marquee__item">{dest}</span>
          <span class="pri-marquee__sep">✦</span>
        </>
      ))}
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════
       STATS BAR
  ══════════════════════════════════════════════════════════ -->
  <div class="pri-stats" aria-label="Cifras del catálogo de paquetes">
    <div class="container pri-stats__inner">
      <div class="pri-stat">
        <strong>{allPackages.length > 0 ? allPackages.length : '12'}</strong>
        <span>Paquetes disponibles</span>
      </div>
      <div class="pri-stat">
        <strong>{uniqueDestinations.size > 0 ? uniqueDestinations.size : '18'}</strong>
        <span>Destinos</span>
      </div>
      {activeCategories.length > 0 && (
        <div class="pri-stat">
          <strong>{activeCategories.length}</strong>
          <span>Estilos de viaje</span>
        </div>
      )}
      <div class="pri-stat">
        <strong>4–14</strong>
        <span>Noches de duración</span>
      </div>
      <div class="pri-stat">
        <strong>≤12</strong>
        <span>Personas por grupo</span>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════
       CATALOG — one section per travel category
  ══════════════════════════════════════════════════════════ -->
  <div class="pri-catalog-wrap" id="catalogo">

    <!-- Section heading -->
    <div class="container">
      <div class="pri-catalog__head">
        <div class="pri-catalog__head-left">
          <p class="pri-catalog__eyebrow">Catálogo completo</p>
          <h2 class="pri-catalog__title">
            Encuentra tu viaje
          </h2>
        </div>
        <p class="pri-catalog__subtitle">
          Cada estilo de viaje tiene su propio ritmo. Elige la experiencia
          que más te identifica y descubre los itinerarios disponibles.
        </p>
      </div>
    </div>

    <!-- Filter bar — sticky jump nav between categories -->
    {categoryGroups.length > 1 && (
      <div class="pri-filter-bar" aria-label="Filtrar por estilo de viaje">
        <div class="container">
          <nav class="pri-filter-pills">
            {categoryGroups.map((group) => (
              <a
                href={`#tcat-section-${group.slug}`}
                class="pri-filter-pill"
                data-filter={group.slug}
              >
                {group.name}
              </a>
            ))}
          </nav>
        </div>
      </div>
    )}

    <!-- Category sections -->
    {categoryGroups.length > 0 ? (
      <div class="tcat-list">
        {categoryGroups.map((group, gi) => (
          <section
            class="tcat-section"
            id={`tcat-section-${group.slug}`}
            data-section-index={gi}
            aria-labelledby={`tcat-title-${group.slug}`}
          >
            {group.heroImage && (
              <div class="tcat-section__bg" aria-hidden="true">
                <img src={group.heroImage} alt="" loading="lazy" />
              </div>
            )}

            <div class="container">
              <div class="tcat-layout">

                <!-- TOP — category header -->
                <div class="tcat-header" data-section-index={gi}>
                  <div class="tcat-header__meta">
                    <p class="tcat-intro__eyebrow">Estilo de viaje</p>
                    <div class="tcat-header__name-row">
                      <div class="tcat-icon-wrap" aria-hidden="true">
                        <LucideIcon
                          name={group.icon || 'map'}
                          size={22}
                          class="tcat-icon"
                        />
                      </div>
                      <h3 class="tcat-name" id={`tcat-title-${group.slug}`}>
                        {group.name}
                      </h3>
                    </div>
                    {group.description && (
                      <p class="tcat-desc">{group.description}</p>
                    )}
                  </div>
                  <div class="tcat-count">
                    <strong class="tcat-count__num">{group.packages.length}</strong>
                    <span>{group.packages.length === 1 ? 'paquete' : 'paquetes'} disponibles</span>
                  </div>
                </div>

                <!-- BOTTOM — packages carousel -->
                <div class="tcat-carousel-outer" data-carousel-id={group.slug}>
                  <button
                    class="tcat-nav tcat-nav--prev"
                    aria-label="Paquete anterior"
                    type="button"
                    disabled
                  >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M15 18l-6-6 6-6"/>
                    </svg>
                  </button>

                  <div class="tcat-tours" id={`pkg-grid-${group.slug}`}>
                    {group.packages.map((pkg, pi) => (
                      <div
                        class={`tcat-card-wrap${group.packages.length === 1 ? ' tcat-card-wrap--wide' : ''}`}
                        data-card-i={pi}
                      >
                        <ProductCard product={pkg} />
                      </div>
                    ))}
                  </div>

                  <button
                    class="tcat-nav tcat-nav--next"
                    aria-label="Siguiente paquete"
                    type="button"
                  >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M9 18l6-6-6-6"/>
                    </svg>
                  </button>

                  <div class="tcat-progress" aria-hidden="true">
                    <div class="tcat-progress__track">
                      <div class="tcat-progress__fill"></div>
                    </div>
                    <span class="tcat-progress__count"></span>
                  </div>
                </div>

              </div>
            </div>
          </section>
        ))}
      </div>
    ) : (
      <div class="container">
        <div class="pri-empty">
          <div class="pri-empty__icon" aria-hidden="true">⌖</div>
          <h3 class="pri-empty__title">Catálogo en preparación</h3>
          <p class="pri-empty__text">
            Muy pronto tendremos paquetes disponibles. Contáctanos para diseñar tu itinerario a medida.
          </p>
        </div>
      </div>
    )}

  </div>

  <!-- ══════════════════════════════════════════════════════════
       HOW IT WORKS
  ══════════════════════════════════════════════════════════ -->
  <section class="pri-process" aria-labelledby="pri-process-title">
    <div class="container">

      <div class="pri-process__head">
        <p class="pri-process__eyebrow">Simple por diseño</p>
        <h2 class="pri-process__title" id="pri-process-title">
          Cómo funciona
        </h2>
      </div>

      <div class="pri-process__steps">
        {steps.map((step, i) => (
          <div class="pri-step reveal-item" data-delay={i * 110}>
            <div class="pri-step__num" aria-hidden="true">{step.num}</div>
            <div class="pri-step__icon-wrap" aria-hidden="true">
              <LucideIcon name={step.icon} size={22} class="pri-step__icon" />
            </div>
            <h3 class="pri-step__title">{step.title}</h3>
            <p class="pri-step__desc">{step.description}</p>
            {i < steps.length - 1 && (
              <div class="pri-step__connector" aria-hidden="true">
                <span class="pri-step__connector-arrow">→</span>
              </div>
            )}
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       WHY NUNA TERRA
  ══════════════════════════════════════════════════════════ -->
  <section class="pri-trust" aria-labelledby="pri-trust-title">
    <div class="container">

      <div class="pri-trust__head">
        <p class="pri-trust__eyebrow">Por qué elegirnos</p>
        <h2 class="pri-trust__title" id="pri-trust-title">
          Cada detalle tiene un porqué
        </h2>
      </div>

      <div class="pri-trust__grid">
        {trustItems.map((item, i) => (
          <div class="pri-trust-item reveal-item" data-delay={i * 80}>
            <div class="pri-trust-item__icon-wrap" aria-hidden="true">
              <LucideIcon name={item.icon} size={20} class="pri-trust-item__icon" />
            </div>
            <h3 class="pri-trust-item__title">{item.title}</h3>
            <p class="pri-trust-item__desc">{item.description}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       CUSTOM PACKAGE CTA — full-bleed
  ══════════════════════════════════════════════════════════ -->
  <section class="pri-custom" aria-labelledby="pri-custom-title">
    <div class="pri-custom__bg" aria-hidden="true">
      <img
        src={customCtaImage}
        alt=""
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="pri-custom__overlay" aria-hidden="true"></div>

    <div class="container pri-custom__content">
      <p class="pri-custom__eyebrow">Itinerario a medida</p>
      <h2 class="pri-custom__title" id="pri-custom-title">
        ¿No encuentras<br />lo que buscas?
      </h2>
      <p class="pri-custom__subtitle">
        Diseñamos tu itinerario desde cero según tus días, intereses y tamaño
        de grupo. Un asesor de Nuna Terra trabaja contigo hasta que el viaje
        sea exactamente lo que imaginas.
      </p>
      <div class="pri-custom__actions">
        <a href="/contacto" class="pri-custom__btn pri-custom__btn--primary">
          Diseñar mi itinerario
        </a>
        <a
          href={site.whatsappUrl}
          class="pri-custom__btn pri-custom__btn--ghost"
          target="_blank"
          rel="noopener noreferrer"
        >
          Hablar por WhatsApp ↗
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      /* ── Stagger delay per card ───────────────────────── */
      document.querySelectorAll('.tcat-tours').forEach((grid) => {
        grid.querySelectorAll('.tcat-card-wrap').forEach((card, i) => {
          card.style.setProperty('--card-delay', `${i * 100}ms`);
        });
      });

      /* ── IntersectionObserver reveals ────────────────── */
      if ('IntersectionObserver' in window) {
        const sectionObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const el = entry.target;
                const delay = parseInt(el.dataset.delay || '0', 10);
                setTimeout(() => el.classList.add('is-visible'), delay);
                sectionObserver.unobserve(el);
              }
            });
          },
          { threshold: 0.06, rootMargin: '0px 0px -20px 0px' }
        );
        document.querySelectorAll('.reveal-item').forEach((el) =>
          sectionObserver.observe(el)
        );

        const introObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                introObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        document.querySelectorAll('.tcat-header').forEach((el) =>
          introObserver.observe(el)
        );

        const cardObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-card-visible');
                cardObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.04, rootMargin: '0px 0px -24px 0px' }
        );
        document.querySelectorAll('.tcat-card-wrap').forEach((card) =>
          cardObserver.observe(card)
        );
      } else {
        document.querySelectorAll('.reveal-item').forEach((el) => el.classList.add('is-visible'));
        document.querySelectorAll('.tcat-header').forEach((el) => el.classList.add('is-visible'));
        document.querySelectorAll('.tcat-card-wrap').forEach((card) => card.classList.add('is-card-visible'));
      }

      /* ── Filter bar — sticky shadow + scroll spy ──────── */
      const filterBar = document.querySelector('.pri-filter-bar');
      if (filterBar) {
        // Sentinel for sticky detection
        const sentinel = document.createElement('div');
        sentinel.style.cssText = 'height:1px;pointer-events:none;position:absolute;top:0;left:0;right:0;';
        filterBar.parentElement.style.position = 'relative';
        filterBar.parentElement.insertBefore(sentinel, filterBar);

        new IntersectionObserver(
          ([e]) => filterBar.classList.toggle('is-stuck', !e.isIntersecting),
          { threshold: 1 }
        ).observe(sentinel);

        // Scroll spy — highlight active pill
        const pills = document.querySelectorAll('.pri-filter-pill');
        const sections = document.querySelectorAll('.tcat-section[id]');

        new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const id = entry.target.id;
                pills.forEach((p) => {
                  const active = p.getAttribute('href') === `#${id}`;
                  p.classList.toggle('is-active', active);
                  if (active) p.scrollIntoView({ inline: 'nearest', block: 'nearest', behavior: 'smooth' });
                });
              }
            });
          },
          { threshold: 0.4 }
        ).observe(...sections.length ? [sections[0]] : []);

        // Observe all sections for spy
        sections.forEach((s) => {
          new IntersectionObserver(
            ([e]) => {
              if (e.isIntersecting) {
                const id = e.target.id;
                pills.forEach((p) => {
                  p.classList.toggle('is-active', p.getAttribute('href') === `#${id}`);
                });
              }
            },
            { threshold: 0.35, rootMargin: '-10% 0px -55% 0px' }
          ).observe(s);
        });
      }

      /* ── Carousel init ────────────────────────────────── */
      document.querySelectorAll('.tcat-carousel-outer').forEach((outer) => {
        const track = outer.querySelector('.tcat-tours');
        const prevBtn = outer.querySelector('.tcat-nav--prev');
        const nextBtn = outer.querySelector('.tcat-nav--next');
        const fill = outer.querySelector('.tcat-progress__fill');
        const countEl = outer.querySelector('.tcat-progress__count');
        const cards = outer.querySelectorAll('.tcat-card-wrap');

        if (!track || !cards.length) return;

        const getCardWidth = () => {
          const c = cards[0];
          if (!c) return 300;
          const gap = parseInt(getComputedStyle(track).gap) || 20;
          return c.offsetWidth + gap;
        };

        const update = () => {
          const maxScroll = track.scrollWidth - track.clientWidth;
          if (prevBtn) prevBtn.disabled = track.scrollLeft < 4;
          if (nextBtn) nextBtn.disabled = track.scrollLeft >= maxScroll - 4;

          if (fill) {
            const pct = maxScroll <= 0 ? 100 : (track.scrollLeft / maxScroll) * 100;
            fill.style.width = `${Math.max(8, Math.min(100, pct))}%`;
          }
          if (countEl) {
            const w = getCardWidth();
            const idx = w > 0 ? Math.round(track.scrollLeft / w) + 1 : 1;
            countEl.textContent = `${Math.min(idx, cards.length)} / ${cards.length}`;
          }
        };

        const checkScrollable = () => {
          const scrollable = track.scrollWidth > track.clientWidth + 8;
          outer.toggleAttribute('data-scrollable', scrollable);
          update();
        };

        prevBtn?.addEventListener('click', () => {
          track.scrollBy({ left: -getCardWidth(), behavior: 'smooth' });
        });
        nextBtn?.addEventListener('click', () => {
          track.scrollBy({ left: getCardWidth(), behavior: 'smooth' });
        });
        track.addEventListener('scroll', update, { passive: true });

        // Drag-to-scroll
        let isDragging = false, startX = 0, startScroll = 0;
        track.addEventListener('mousedown', (e) => {
          isDragging = true;
          startX = e.pageX - track.offsetLeft;
          startScroll = track.scrollLeft;
          track.classList.add('is-dragging');
        });
        window.addEventListener('mousemove', (e) => {
          if (!isDragging) return;
          e.preventDefault();
          track.scrollLeft = startScroll - (e.pageX - track.offsetLeft - startX);
        });
        window.addEventListener('mouseup', () => {
          isDragging = false;
          track.classList.remove('is-dragging');
        });

        checkScrollable();
        if ('ResizeObserver' in window) {
          new ResizeObserver(checkScrollable).observe(track);
        }
        countEl && (countEl.textContent = `1 / ${cards.length}`);

        /* Auto-rotation: advance one card every 4.5s, loop back at end */
        let autoTimer = null;
        const autoAdvance = () => {
          const maxScroll = track.scrollWidth - track.clientWidth;
          if (maxScroll <= 0) return;
          if (track.scrollLeft >= maxScroll - 4) {
            track.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            track.scrollBy({ left: getCardWidth(), behavior: 'smooth' });
          }
        };
        const startAuto = () => {
          if (autoTimer) return;
          autoTimer = setInterval(autoAdvance, 4500);
        };
        const stopAuto = () => {
          clearInterval(autoTimer);
          autoTimer = null;
        };
        outer.addEventListener('mouseenter', stopAuto);
        outer.addEventListener('mouseleave', startAuto);
        outer.addEventListener('touchstart', () => {
          stopAuto();
          setTimeout(startAuto, 6000);
        }, { passive: true });
        startAuto();
      });

      /* ── Smooth anchor scrolling ──────────────────────── */
      document.querySelectorAll('a[href^="#"]').forEach((a) => {
        a.addEventListener('click', (e) => {
          const target = document.querySelector(a.getAttribute('href'));
          if (!target) return;
          e.preventDefault();
          const offset = 56; // filter bar height
          const top = target.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({ top, behavior: 'smooth' });
        });
      });
    })();
  </script>

</BaseLayout>
