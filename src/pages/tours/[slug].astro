---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import ProductCard from '@/components/cards/ProductCard.astro';
import LucideIcon from '@/components/cards/LucideIcon.astro';
import ProductItinerary from '@/components/sections/ProductItinerary.astro';
import { getTours, getProductBySlug, getRelatedProducts, getTravelCategories, getProductPromotions } from '@/lib/content';
import { site } from '@/lib/site';
import { buildWaUrl, tourMessage } from '@/lib/whatsapp';
import './TourDetail.scss';

export const prerender = false;

const slug = Astro.params.slug || '';
const product = await getProductBySlug(slug, 'tour');
if (!product) return Astro.redirect('/tours');

const [related, allCategories, promotions] = await Promise.all([
  getRelatedProducts(slug, 'es', 3),
  getTravelCategories(),
  getProductPromotions(slug),
]);

const productCategories = allCategories.filter(
  (cat) => product.categorySlugs?.includes(cat.slug)
);

const waMsg = tourMessage(product);
const waUrl1 = buildWaUrl('51978388196', waMsg);
---

<BaseLayout
  title={`${product.title} | Nuna Terra Perú`}
  description={product.seoDescription || product.shortDescription || product.subtitle}
>
  <!-- HERO -->
  <section class="pkg-hero" aria-labelledby="tour-hero-title">
    <img
      src={product.heroImage}
      alt={product.title}
      class="pkg-hero__img"
      loading="eager"
      fetchpriority="high"
    />
    <div class="pkg-hero__overlay" aria-hidden="true"></div>

    <div class="container pkg-hero__content">
      <nav class="pkg-breadcrumb" aria-label="Ubicación en el sitio">
        <a href="/tours">← Tours</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{product.title}</span>
      </nav>

      <p class="pkg-hero__eyebrow">Tour y experiencia</p>
      <h1 class="pkg-hero__title" id="tour-hero-title">{product.title}</h1>

      {product.subtitle && (
        <p class="pkg-hero__subtitle">{product.subtitle}</p>
      )}

      <div class="pkg-hero__actions">
        <a href="/contacto" class="pkg-hero__btn pkg-hero__btn--primary">
          Solicitar cotización
        </a>
        <a
          href={waUrl1}
          class="pkg-hero__btn pkg-hero__btn--ghost"
          target="_blank"
          rel="noopener noreferrer"
        >
          WhatsApp ↗
        </a>
      </div>
    </div>
  </section>

  <!-- META CARD — flota entre hero y contenido -->
  <div class="pkg-meta-wrap" aria-label="Detalles del tour">
    <div class="container">
      <div class="pkg-hero__meta">
        {product.durationText && (
          <div class="pkg-meta-item">
            <LucideIcon name="clock" size={15} class="pkg-meta-item__icon" />
            <span class="pkg-meta-item__label">Duración</span>
            <strong class="pkg-meta-item__val">{product.durationText}</strong>
          </div>
        )}
        {product.destinations?.length > 0 && (
          <div class="pkg-meta-item">
            <LucideIcon name="map-pin" size={15} class="pkg-meta-item__icon" />
            <span class="pkg-meta-item__label">Destinos</span>
            <strong class="pkg-meta-item__val">{product.destinations.join(', ')}</strong>
          </div>
        )}
        {product.categories?.length > 0 && (
          <div class="pkg-meta-item">
            <LucideIcon name="gem" size={15} class="pkg-meta-item__icon" />
            <span class="pkg-meta-item__label">Tipo</span>
            <strong class="pkg-meta-item__val">{product.categories[0]}</strong>
          </div>
        )}
        {product.serviceType && (
          <div class="pkg-meta-item">
            <LucideIcon name="headphones" size={15} class="pkg-meta-item__icon" />
            <span class="pkg-meta-item__label">Servicio</span>
            <strong class="pkg-meta-item__val">{product.serviceType}</strong>
          </div>
        )}
        {product.difficulty && (
          <div class="pkg-meta-item">
            <LucideIcon name="activity" size={15} class="pkg-meta-item__icon" />
            <span class="pkg-meta-item__label">Dificultad</span>
            <strong class="pkg-meta-item__val">{product.difficulty}</strong>
          </div>
        )}
        <div class="pkg-meta-item">
          <LucideIcon name="globe" size={15} class="pkg-meta-item__icon" />
          <span class="pkg-meta-item__label">Región</span>
          <strong class="pkg-meta-item__val">
            {product.region === 'sierra' ? 'Sierra' : product.region === 'costa' ? 'Costa' : 'Selva'}
          </strong>
        </div>
      </div>
    </div>
  </div>

  <!-- MAIN DETAIL -->
  <section class="pkg-detail">
    <div class="container pkg-detail__layout">

      <!-- ── MAIN CONTENT ── -->
      <div class="pkg-main">

        <!-- Description -->
        {product.description && (
          <div>
            <h2 class="pkg-section-title">
              {product.destinations?.length > 0
                ? `Una experiencia para vivir ${product.destinations[0]} en menos tiempo`
                : 'Una experiencia para vivir el Perú en menos tiempo'}
            </h2>
            <p class="pkg-desc">{product.description}</p>
          </div>
        )}

        <!-- Travel styles this tour belongs to -->
        {productCategories.length > 0 && (
          <div class="pkg-styles">
            <h2 class="pkg-styles__title">Lo que hace este tour único</h2>
            <div class="pkg-styles__grid">
              {productCategories.map((cat) => (
                <div class="pkg-style-item">
                  <div class="pkg-style-item__icon-wrap" aria-hidden="true">
                    <LucideIcon name={cat.icon || 'compass'} size={22} class="pkg-style-item__lucide" />
                  </div>
                  <h3 class="pkg-style-item__name">{cat.name}</h3>
                  {cat.description && (
                    <p class="pkg-style-item__desc">{cat.description}</p>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Places you'll visit -->
        {product.places && product.places.length > 0 && (
          <div>
            <h2 class="pkg-section-title">Lugares que visitarás</h2>
            <div class="pkg-places__list">
              {product.places.map((place) => (
                <span class="pkg-place-tag">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                  </svg>
                  {place}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Gallery -->
        {product.gallery && product.gallery.length > 0 && (
          <div>
            <h2 class="pkg-section-title">Galería</h2>
            <div class="pkg-gallery">
              {product.gallery.slice(0, 5).map((img) => (
                <img
                  src={img.imageUrl}
                  alt={img.altText || product.title}
                  loading="lazy"
                />
              ))}
            </div>
          </div>
        )}

        <!-- Itinerary -->
        {product.itinerary && product.itinerary.length > 0 && (
          <div>
            <h2 class="pkg-section-title">Recorrido del tour</h2>
            <ProductItinerary itinerary={product.itinerary} />
          </div>
        )}

        <!-- Includes / Not includes -->
        {(product.includes?.length > 0 || product.notIncludes?.length > 0) && (
          <div>
            <h2 class="pkg-section-title">Qué incluye este tour</h2>
            <div class="pkg-inclusions">
              {product.includes && product.includes.length > 0 && (
                <div class="pkg-incl-col">
                  <h3>Incluye</h3>
                  <ul>
                    {product.includes.map((item) => (
                      <li>
                        <span class="pkg-check" aria-hidden="true">✓</span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              {product.notIncludes && product.notIncludes.length > 0 && (
                <div class="pkg-incl-col pkg-incl-col--no">
                  <h3>No incluye</h3>
                  <ul>
                    {product.notIncludes.map((item) => (
                      <li>
                        <span class="pkg-dash" aria-hidden="true">—</span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </div>
        )}

        <!-- Recommendations -->
        {product.recommendations && product.recommendations.length > 0 && (
          <div>
            <h2 class="pkg-section-title">Recomendaciones</h2>
            <ul class="pkg-recs">
              {product.recommendations.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        )}

        <!-- Important notes -->
        {product.importantNotes && product.importantNotes.length > 0 && (
          <div>
            <h2 class="pkg-section-title">Notas importantes</h2>
            <ul class="pkg-recs">
              {product.importantNotes.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        )}

        <!-- FAQs -->
        {product.faqs && product.faqs.length > 0 && (
          <div>
            <h2 class="pkg-section-title">Preguntas frecuentes</h2>
            <div class="pkg-faqs">
              {product.faqs.map((faq) => (
                <details class="pkg-faq">
                  <summary>{faq.question}</summary>
                  <p>{faq.answer}</p>
                </details>
              ))}
            </div>
          </div>
        )}

      </div>

      <!-- ── SIDEBAR ── -->
      <aside class="pkg-sidebar" aria-label="Cotización y detalles">
        <div class="pkg-quote">

          <!-- Price -->
          <div class="pkg-quote__price">
            <span class="pkg-quote__from">Desde</span>
            {product.priceFrom ? (
              <strong class="pkg-quote__amount">
                {product.currency} {product.priceFrom.toLocaleString('es-PE')}
              </strong>
            ) : (
              <strong class="pkg-quote__amount pkg-quote__amount--consult">
                A consultar
              </strong>
            )}
            <span class="pkg-quote__per">por persona</span>
          </div>

          <!-- Details -->
          <dl class="pkg-quote__details">
            <span class="pkg-quote__dt">Duración</span>
            <span class="pkg-quote__dd">{product.durationText}</span>

            {product.destinations?.length > 0 && (
              <>
                <span class="pkg-quote__dt">Destinos</span>
                <span class="pkg-quote__dd">{product.destinations.join(' · ')}</span>
              </>
            )}

            {product.places?.length > 0 && (
              <>
                <span class="pkg-quote__dt">Lugares</span>
                <span class="pkg-quote__dd">{product.places.join(' · ')}</span>
              </>
            )}

            {product.categories?.length > 0 && (
              <>
                <span class="pkg-quote__dt">Estilo</span>
                <span class="pkg-quote__dd">{product.categories.join(', ')}</span>
              </>
            )}
          </dl>

          <!-- Promotions (below price details) -->
          {promotions.length > 0 && (
            <div class="pkg-sidebar-promos">
              <div class="pkg-sidebar-promos__header">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                <span>Oferta activa</span>
              </div>

              {promotions.map((promo) => {
                const discount =
                  promo.discountValue && promo.discountType === 'percentage'
                    ? `${promo.discountValue}% OFF`
                    : promo.discountValue && promo.discountType === 'fixed'
                      ? `${product.currency} ${promo.discountValue} OFF`
                      : null;

                const badge = promo.customBadge || promo.badgeText || '';

                const expiresLabel = promo.endDate
                  ? `Válido hasta ${new Date(promo.endDate).toLocaleDateString('es-PE', {
                      day: 'numeric',
                      month: 'long',
                    })}`
                  : null;

                return (
                  <div class="pkg-sidebar-promo-card">
                    {(discount || badge) && (
                      <div class="pkg-sidebar-promo-card__top">
                        {discount && (
                          <span class="pkg-sidebar-promo-card__discount">{discount}</span>
                        )}
                        {badge && (
                          <span class="pkg-sidebar-promo-card__badge">{badge}</span>
                        )}
                      </div>
                    )}

                    <p class="pkg-sidebar-promo-card__title">{promo.title}</p>

                    {promo.subtitle && (
                      <p class="pkg-sidebar-promo-card__sub">{promo.subtitle}</p>
                    )}

                    {promo.notes && (
                      <p class="pkg-sidebar-promo-card__notes">{promo.notes}</p>
                    )}

                    {expiresLabel && (
                      <p class="pkg-sidebar-promo-card__expires">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        {expiresLabel}
                      </p>
                    )}

                    <a href="/contacto" class="pkg-sidebar-promo-card__cta">
                      Aprovechar esta oferta
                      <span aria-hidden="true">→</span>
                    </a>
                  </div>
                );
              })}
            </div>
          )}

          <!-- CTAs -->
          <div class="pkg-quote__actions">
            <a href="/contacto" class="pkg-quote__btn pkg-quote__btn--primary">
              Solicitar cotización
            </a>
            <a
              href={waUrl1}
              class="pkg-quote__btn pkg-quote__btn--wa"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.136.562 4.14 1.541 5.875L.057 23.428a.5.5 0 0 0 .61.61l5.553-1.484A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.882a9.872 9.872 0 0 1-5.031-1.378l-.36-.214-3.733.998 1.011-3.695-.235-.38A9.836 9.836 0 0 1 2.118 12C2.118 6.533 6.533 2.118 12 2.118S21.882 6.533 21.882 12 17.467 21.882 12 21.882z"/></svg>
              WhatsApp · 978 388 196
            </a>
          </div>

          <p class="pkg-quote__note">
            Sin costo de asesoría. Respondemos en menos de 24 h.
          </p>

        </div>
      </aside>

    </div>
  </section>

  <!-- RELATED TOURS -->
  {related.length > 0 && (
    <section class="pkg-related" aria-label="Tours relacionados">
      <div class="container">
        <div class="pkg-related__head">
          <span class="pkg-related__eyebrow">También podrías vivir</span>
          <h2 class="pkg-related__title">Experiencias compatibles</h2>
          <p class="pkg-related__subtitle">Descubre otros tours que pueden complementar tu viaje y brindarte más aventuras increíbles.</p>
        </div>
        
        <div class="pkg-related__carousel" data-carousel="related">
          <button class="pkg-related-nav pkg-related-nav--prev" aria-label="Tour anterior" type="button" disabled>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M15 18l-6-6 6-6"/>
            </svg>
          </button>
          <div class="pkg-related__grid">
            {related.map((item) => (
              <div class="pkg-related__item">
                <ProductCard product={item} />
              </div>
            ))}
          </div>
          <button class="pkg-related-nav pkg-related-nav--next" aria-label="Siguiente tour" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </button>
          <div class="pkg-related-footer" aria-hidden="true">
            <div class="pkg-related-track">
              <div class="pkg-related-fill"></div>
            </div>
            <span class="pkg-related-count"></span>
          </div>
        </div>
      </div>
    </section>
  )}

  <script is:inline>
    (() => {
      document.querySelectorAll('[data-carousel="related"]').forEach((carousel) => {
        const track = carousel.querySelector('.pkg-related__grid');
        const prevBtn = carousel.querySelector('.pkg-related-nav--prev');
        const nextBtn = carousel.querySelector('.pkg-related-nav--next');
        const fill = carousel.querySelector('.pkg-related-fill');
        const countEl = carousel.querySelector('.pkg-related-count');
        const items = carousel.querySelectorAll('.pkg-related__item');

        if (!track || !items.length) return;

        const getItemWidth = () => {
          const item = items[0];
          if (!item) return 300;
          const gap = parseInt(getComputedStyle(track).gap) || 22;
          return item.offsetWidth + gap;
        };

        const update = () => {
          const maxScroll = track.scrollWidth - track.clientWidth;
          if (prevBtn) prevBtn.disabled = track.scrollLeft < 4;
          if (nextBtn) nextBtn.disabled = track.scrollLeft >= maxScroll - 4;
          if (fill) {
            const pct = maxScroll <= 0 ? 100 : (track.scrollLeft / maxScroll) * 100;
            fill.style.width = `${Math.max(8, Math.min(100, pct))}%`;
          }
          if (countEl) {
            const w = getItemWidth();
            const idx = w > 0 ? Math.round(track.scrollLeft / w) + 1 : 1;
            countEl.textContent = `${Math.min(idx, items.length)} / ${items.length}`;
          }
        };

        const checkScrollable = () => {
          const scrollable = track.scrollWidth > track.clientWidth + 8;
          carousel.toggleAttribute('data-scrollable', scrollable);
          update();
        };

        prevBtn?.addEventListener('click', () => track.scrollBy({ left: -getItemWidth(), behavior: 'smooth' }));
        nextBtn?.addEventListener('click', () => track.scrollBy({ left: getItemWidth(), behavior: 'smooth' }));
        track.addEventListener('scroll', update, { passive: true });

        let isDragging = false, startX = 0, startScroll = 0;
        track.addEventListener('mousedown', (e) => {
          isDragging = true;
          startX = e.pageX - track.offsetLeft;
          startScroll = track.scrollLeft;
          track.classList.add('is-dragging');
        });
        window.addEventListener('mousemove', (e) => {
          if (!isDragging) return;
          e.preventDefault();
          track.scrollLeft = startScroll - (e.pageX - track.offsetLeft - startX);
        });
        window.addEventListener('mouseup', () => {
          isDragging = false;
          track.classList.remove('is-dragging');
        });

        checkScrollable();
        if ('ResizeObserver' in window) new ResizeObserver(checkScrollable).observe(track);
        countEl && (countEl.textContent = `1 / ${items.length}`);
      });
    })();
  </script>

</BaseLayout>
