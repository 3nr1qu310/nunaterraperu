---
import LegalLayout from '@/components/layout/LegalLayout.astro';
import { isLocale, type Locale } from '@/lib/i18n';

export function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'pt' } },
    { params: { locale: 'fr' } },
  ];
}

const localeParam = Astro.params.locale;

if (!isLocale(localeParam) || localeParam === 'es') {
  return Astro.redirect('/politica-de-privacidad');
}

const locale = localeParam as Locale;

const copyByLocale = {
