---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Hero from '@/components/ui/Hero.astro';
import SectionHeading from '@/components/sections/SectionHeading.astro';
import ProductCard from '@/components/cards/ProductCard.astro';
import { getProductBySlug, getPackages } from '@/lib/content';
import { isLocale, type Locale } from '@/lib/i18n';

export async function getStaticPaths() {
  const locales = ['en', 'pt', 'fr'];
  const packages = await getPackages();
  return locales.flatMap((locale) =>
    packages.map((p) => ({ params: { locale, slug: p.slug } }))
  );
}

const localeParam = Astro.params.locale;
const slug = Astro.params.slug || '';

if (!isLocale(localeParam)) {
  return Astro.redirect('/paquetes');
}

const locale = localeParam as Locale;

const product = await getProductBySlug(slug, 'package', locale);

if (!product) {
  return Astro.redirect(`/${locale}/packages`);
}

const allPackages = await getPackages(locale);
const related = allPackages
  .filter((item) => item.slug !== product.slug)
  .slice(0, 3);

const copyByLocale = {
  en: {
    eyebrow: 'Travel package',
    quote: 'Request a quote',
    whatsapp: 'Chat on WhatsApp',
    duration: 'Duration',
    destinations: 'Destinations',
    service: 'Service',
    difficulty: 'Difficulty',
    custom: 'Customizable',
    routeTitle: 'A journey to experience Peru from its essence',
    itinerary: 'Travel itinerary',
    includesNotIncludes: 'Includes / Does not include',
    includes: 'Includes',
    notIncludes: 'Does not include',
    recommendations: 'Recommendations',
    from: 'From',
    relatedTitle: 'You may also be interested in',
    contactHref: '/en/contact',
  },

  pt: {
    eyebrow: 'Pacote turístico',
    quote: 'Solicitar cotação',
    whatsapp: 'Falar pelo WhatsApp',
    duration: 'Duração',
    destinations: 'Destinos',
    service: 'Serviço',
    difficulty: 'Dificuldade',
    custom: 'Personalizável',
    routeTitle: 'Uma rota para viver o Peru a partir da sua essência',
    itinerary: 'Itinerário da viagem',
    includesNotIncludes: 'Inclui / Não inclui',
    includes: 'Inclui',
    notIncludes: 'Não inclui',
    recommendations: 'Recomendações',
    from: 'A partir de',
    relatedTitle: 'Você também pode se interessar',
    contactHref: '/pt/contact',
  },

  fr: {
    eyebrow: 'Forfait touristique',
    quote: 'Demander un devis',
    whatsapp: 'Écrire sur WhatsApp',
    duration: 'Durée',
    destinations: 'Destinations',
    service: 'Service',
    difficulty: 'Difficulté',
    custom: 'Personnalisable',
    routeTitle: 'Un itinéraire pour vivre le Pérou depuis son essence',
    itinerary: 'Itinéraire du voyage',
    includesNotIncludes: 'Inclus / Non inclus',
    includes: 'Inclus',
    notIncludes: 'Non inclus',
    recommendations: 'Recommandations',
    from: 'À partir de',
    relatedTitle: 'Vous pourriez aussi aimer',
    contactHref: '/fr/contact',
  },
};

const copy = copyByLocale[locale];

const pageTitle = `${product.seoTitle || product.title} | Nuna Terra Perú`;
const pageDescription = product.seoDescription || product.description || product.subtitle || '';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Hero
    eyebrow={copy.eyebrow}
    title={product.title}
    subtitle={product.subtitle}
    image={product.heroImage}
    primaryText={copy.quote}
    primaryHref={copy.contactHref}
    secondaryText={copy.whatsapp}
    secondaryHref={copy.contactHref}
  />

  <section class="section package-detail">
    <div class="container detail-layout">
      <div>
        <div class="summary-grid">
          <div>
            <b>{copy.duration}</b>
            <span>{product.durationText}</span>
          </div>

          <div>
            <b>{copy.destinations}</b>
            <span>{product.destinations.join(' · ')}</span>
          </div>

          <div>
            <b>{copy.service}</b>
            <span>{product.serviceType || copy.custom}</span>
          </div>

          <div>
            <b>{copy.difficulty}</b>
            <span>{product.difficulty || copy.custom}</span>
          </div>
        </div>

        <SectionHeading
          title={copy.routeTitle}
          subtitle={product.description}
        />

        {product.itinerary?.length > 0 && (
          <section>
            <h2 class="h2 small">{copy.itinerary}</h2>

            <div class="timeline">
              {product.itinerary.map((day) => (
                <details open>
                  <summary>
                    <span>{day.day}</span>
                    {day.title}
                  </summary>

                  <p>{day.description}</p>
                </details>
              ))}
            </div>
          </section>
        )}

        <section class="section--tight">
          <h2 class="h2 small">{copy.includesNotIncludes}</h2>

          <div class="two-cols">
            <div class="list-card">
              <h3>{copy.includes}</h3>
              {product.includes?.map((item) => (
                <p>✓ {item}</p>
              ))}
            </div>

            <div class="list-card">
              <h3>{copy.notIncludes}</h3>
              {product.notIncludes?.map((item) => (
                <p>— {item}</p>
              ))}
            </div>
          </div>
        </section>

        {product.recommendations?.length > 0 && (
          <section class="section--tight">
            <h2 class="h2 small">{copy.recommendations}</h2>

            <div class="list-card">
              {product.recommendations.map((item) => (
                <p>✓ {item}</p>
              ))}
            </div>
          </section>
        )}
      </div>

      <aside class="quote-card">
        <span>{copy.from}</span>
        <strong>{product.currency} {product.priceFrom}</strong>
        <p>{product.durationText}</p>

        <a class="btn btn--primary" href={copy.contactHref}>
          {copy.quote}
        </a>

        <a class="btn btn--outline-dark" href={copy.contactHref}>
          WhatsApp
        </a>
      </aside>
    </div>
  </section>

  {related.length > 0 && (
    <section class="section">
      <div class="container">
        <SectionHeading title={copy.relatedTitle} />

        <div class="grid grid--3">
          {related.map((item) => (
            <ProductCard product={item} />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style lang="scss">
  .detail-layout {
    display: grid;
    grid-template-columns: 1fr 330px;
    gap: 34px;
    align-items: start;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 42px;
  }

  .summary-grid div,
  .list-card,
  .quote-card {
    background: white;
    border: 1px solid rgba(90, 62, 43, .12);
    border-radius: var(--radius-md);
    padding: 20px;
    box-shadow: 0 10px 32px rgba(37, 37, 37, .06);
  }

  .summary-grid b {
    display: block;
    color: var(--color-earth);
  }

  .summary-grid span {
    font-size: .9rem;
  }

  .small {
    font-size: 2.4rem;
    margin-bottom: 20px;
  }

  .timeline {
    border-left: 2px solid var(--color-sand);
    padding-left: 22px;
  }

  .timeline details {
    background: white;
    border-radius: 18px;
    margin: 14px 0;
    padding: 18px;
    border: 1px solid rgba(90, 62, 43, .12);
  }

  .timeline summary {
    cursor: pointer;
    font-weight: 800;
    color: var(--color-earth);
  }

  .timeline summary span {
    color: var(--color-green);
    margin-right: 12px;
  }

  .two-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .quote-card {
    position: sticky;
    top: 130px;
  }

  .quote-card span {
    color: rgba(37, 37, 37, .65);
  }

  .quote-card strong {
    display: block;
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--color-earth);
    line-height: 1;
  }

  .quote-card .btn {
    width: 100%;
    margin-top: 12px;
  }

  @media(max-width: 900px) {
    .detail-layout,
    .two-cols {
      grid-template-columns: 1fr;
    }

    .summary-grid {
      grid-template-columns: 1fr 1fr;
    }

    .quote-card {
      position: static;
    }
  }

  @media(max-width: 600px) {
    .summary-grid {
      grid-template-columns: 1fr;
    }
  }
</style>