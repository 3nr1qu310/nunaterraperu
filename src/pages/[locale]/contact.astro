const contactHref = `/${locale}/contact`;
---

<BaseLayout title={copy.pageTitle} description={copy.heroSubtitle}>
  <Hero
    eyebrow={copy.heroEyebrow}
    title={copy.heroTitle}
    subtitle={copy.heroSubtitle}
    image="/images/contact-hero.jpg"
    primaryText={copy.heroPrimary}
    primaryHref={site.whatsappUrl}
    secondaryText={copy.heroSecondary}
    secondaryHref="#formulario"
  />

  <section class="section section--tight">
    <div class="container grid grid--4">
      {copy.channels.map((item) => (
        <div class="card contact-card">
          <h3>{item}</h3>
          <p>{copy.channelDesc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section" id="formulario">
    <div class="container contact-layout">
      <div>
        <SectionHeading title={copy.formTitle} subtitle={copy.formSubtitle} />

        <form class="form" id="lead-form">
          <input name="full_name" placeholder={copy.fullName} required />
          <input name="email" type="email" placeholder={copy.email} />
          <input name="phone" placeholder={copy.phone} required />
          <input name="country" placeholder={copy.country} />

          <select name="interest_type">
            <option value="general_question">{copy.interestType}</option>
            <option value="package">{copy.interestPackage}</option>
            <option value="tour">{copy.interestTour}</option>
            <option value="custom_trip">{copy.interestCustom}</option>
          </select>

          <select name="destinations_interest">
            <option value="">{copy.destinationDefault}</option>
            {copy.destinations.map((d) => <option>{d}</option>)}
          </select>

          <input name="travel_date" type="date" placeholder={copy.travelDate} />
          <input name="number_of_people" type="number" min="1" placeholder={copy.travelers} />

          <select name="duration_range">
            <option value="">{copy.durationDefault}</option>
            {copy.durations.map((d) => <option>{d}</option>)}
          </select>

          <select name="travel_style">
            <option value="">{copy.styleDefault}</option>
            {copy.styles.map((s) => <option>{s}</option>)}
          </select>

          <textarea name="message" rows="5" placeholder={copy.message}></textarea>

          <label>
            <input name="consent" type="checkbox" required />
            {copy.consent}
          </label>

          <input type="hidden" name="source" value="contact_page" />
          <input type="hidden" name="locale" value={locale} />

          <button class="btn btn--primary" type="submit">{copy.submit}</button>
          <p class="form-message" id="form-message" aria-live="polite"></p>
        </form>
      </div>

      <aside class="side">
        <h3>{copy.sideTitle}</h3>
        <p>{copy.sideDesc}</p>
        <p>{site.whatsapp}</p>
        <p>{site.email}</p>
        <p>{site.location}</p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  .contact-card { padding: 24px; }
  .contact-card h3 { font-family: var(--font-display); font-size: 1.8rem; color: var(--color-earth); margin: 0; }
  .contact-layout { display: grid; grid-template-columns: 1fr 350px; gap: 34px; align-items: start; }
  .form { display: grid; gap: 14px; }
  .form-message { font-weight: 700; color: var(--color-green); margin: 4px 0 0; }
  .form input, .form select, .form textarea { width: 100%; border: 1px solid rgba(90,62,43,.18); border-radius: 16px; background: white; padding: 14px 16px; }
  .form input:focus, .form textarea:focus, .form select:focus { outline: 2px solid rgba(47,93,80,.25); border-color: var(--color-green); }
  .side { position: sticky; top: 130px; background: var(--color-earth); color: var(--color-ivory); padding: 28px; border-radius: var(--radius-md); }
  .side h3 { font-family: var(--font-display); font-size: 2rem; margin: 0 0 10px; color: var(--color-ivory); }
  @media (max-width: 900px) {
    .contact-layout { grid-template-columns: 1fr; }
    .side { position: static; }
  }
</style>

<script is:inline define:vars={{ sending: copy.sending, success: copy.success, error: copy.error }}>
  const form = document.querySelector('#lead-form');
  const message = document.querySelector('#form-message');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());
    message.textContent = sending;

    try {
      const response = await fetch('/api/leads', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const result = await response.json();
      if (!response.ok || !result.ok) throw new Error(result.message || 'Error');
      message.textContent = success;
      form.reset();
    } catch {
      message.textContent = error;
    }
  });
</script>
