---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import HomeHero from '@/components/home/HomeHero.astro';
import HomeValueProps from '@/components/home/HomeValueProps.astro';
import HomeRegions from '@/components/home/HomeRegions.astro';
import HomeProductsShowcase from '@/components/home/HomeProductsShowcase.astro';
import HomePremiumCta from '@/components/home/HomePremiumCta.astro';
import HomeDestinations from '@/components/home/HomeDestinations.astro';
import HomeReviews from '@/components/home/HomeReviews.astro';
import HomeReveal from '@/components/home/HomeReveal.astro';
import { getRegions, getDestinations, getPackages, getTours } from '@/lib/content';
import { isLocale, type Locale } from '@/lib/i18n';
import { site } from '@/lib/site';

const localeParam = Astro.params.locale;

if (!isLocale(localeParam)) {
  return Astro.redirect('/');
}

const locale = localeParam as Locale;

if (locale === 'es') {
  return Astro.redirect('/');
}

