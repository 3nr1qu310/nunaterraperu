const copy = copyByLocale[locale];

const regions = await getRegions(locale);
const destinations = await getDestinations(locale);
const packages = await getPackages(locale);
const tours = await getTours(locale);
---

<BaseLayout title={copy.pageTitle} description={copy.pageDescription}>
  <HomeHero copy={copy} heroImage="/images/home-hero.jpg" />

  <HomeValueProps props={copy.props} />

  <HomeRegions
    regions={regions}
    eyebrow={copy.regionsEyebrow}
    title={copy.regionsTitle}
    subtitle={copy.regionsSubtitle}
    exploreText={copy.exploreRegion}
    baseHref={copy.routes.destinations}
  />

  <HomeProductsShowcase
    variant="dark"
    eyebrow={copy.packagesEyebrow}
    title={copy.packagesTitle}
    subtitle={copy.packagesSubtitle}
    buttonText={copy.packagesButton}
    buttonHref={copy.routes.packages}
    products={packages.slice(0, 6)}
  />

  <HomeProductsShowcase
    variant="light"
    animationType="flip"
    eyebrow={copy.toursEyebrow}
    title={copy.toursTitle}
    subtitle={copy.toursSubtitle}
    buttonText={copy.toursButton}
    buttonHref={copy.routes.tours}
    products={tours.slice(0, 6)}
  />

  <HomePremiumCta
    eyebrow={copy.premiumEyebrow}
    title={copy.premiumTitle}
    text={copy.premiumText}
    primaryText={copy.premiumPrimary}
    primaryHref={copy.routes.contact}
    secondaryText={copy.premiumSecondary}
    secondaryHref={site.whatsappUrl}
  />

  <HomeDestinations
    destinations={destinations.slice(0, 6)}
    eyebrow={copy.destinationsEyebrow}
    title={copy.destinationsTitle}
    subtitle={copy.destinationsSubtitle}
    buttonText={copy.destinationsButton}
    buttonHref={copy.routes.destinations}
  />

  <HomeReviews
    eyebrow={copy.reviewsEyebrow}
    title={copy.reviewsTitle}
    reviews={copy.reviews}
  />

  <HomeReveal />
</BaseLayout>