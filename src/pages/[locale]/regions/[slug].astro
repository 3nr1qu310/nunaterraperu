---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import SectionHeading from '@/components/sections/SectionHeading.astro';
import ProductCard from '@/components/cards/ProductCard.astro';
import PeruRegionMap from '@/components/maps/PeruRegionMap.astro';

import {
  getRegions,
  getRegionBySlug,
  getDestinations,
  getProductsByRegion,
} from '@/lib/content';

import { isLocale, type Locale } from '@/lib/i18n';
import '../../regiones/RegionDetail.scss';

export const prerender = false;

const localeParam = Astro.params.locale;
const slug        = Astro.params.slug || '';

if (!isLocale(localeParam)) {
  return Astro.redirect('/regiones');
}

const locale = localeParam as Locale;

const region = await getRegionBySlug(slug, locale);

if (!region) {
  return Astro.redirect(`/${locale}/destinations`);
}

const allRegions = await getRegions(locale);

const allDestinations = await getDestinations(locale);

const regionDestinations = allDestinations
  .filter((destination) => destination.region === region.slug)
  .slice(0, 5);

const mapDestinations = allDestinations.filter(
  (d) => d.region === region.slug
);

const regionProducts = await getProductsByRegion(region.slug, locale);

const packages = regionProducts.filter((product) => product.type === 'package');
const tours    = regionProducts.filter((product) => product.type === 'tour');

const featuredDestination   = regionDestinations[0];
const secondaryDestinations = regionDestinations.slice(1, 5);

const heroImage =
  region.heroImage ||
  region.cardImage ||
  '/images/placeholders/destination-placeholder.jpg';

const storyImage =
  featuredDestination?.cardImage ||
  featuredDestination?.heroImage ||
  region.cardImage ||
  region.heroImage ||
  '/images/placeholders/destination-placeholder.jpg';

/* ─── Copy by locale ─── */
const copyByLocale = {
  en: {
    eyebrow:             'Destinations in Peru',
    exploreDestinations: 'Explore destinations',
    designTrip:          'Design my trip',
    contactHref:         `/${locale}/contact`,
    mapTitle:            `Locate the destinations of ${region.name}`,
    mapSubtitle:         `Visually explore the main destinations of ${region.name.toLowerCase()} and discover what experiences you can live in each area.`,
    destinationsEyebrow: 'Iconic places',
    destinationsTitle:   `Main destinations of ${region.name}`,
    featuredLabel:       'Featured destination',
    seeDestination:      'See destination →',
    packagesEyebrow:     'Related experiences',
    packagesTitle:       `Packages to experience ${region.name}`,
    packagesSubtitle:    'Routes designed to discover the territory with organization, time and purpose.',
    toursTitle:          'Tours to explore in less time',
    toursSubtitle:       'Short experiences to connect with essential places in this region.',
    storyEyebrow:        'Culture and essence',
    storyTitle:          'A region to experience Peru from another perspective',
    storyBody:           `Beyond its landscapes, this region invites you to connect with the identity of Peru: its paths, its people, its flavors and its way of welcoming every traveler.`,
    ctaTitle:            `Want to discover ${region.name.toLowerCase()} your way?`,
    ctaSubtitle:         'We design a personalized route based on your days, interests and travel style.',
    ctaPrimary:          'Start planning',
    ctaSecondary:        'Talk to an advisor',
    prevPackage:         'Previous package',
    nextPackage:         'Next package',
    prevTour:            'Previous tour',
    nextTour:            'Next tour',
  },

  pt: {
    eyebrow:             'Destinos do Peru',
    exploreDestinations: 'Explorar destinos',
    designTrip:          'Desenhar minha viagem',
    contactHref:         `/${locale}/contact`,
    mapTitle:            `Localize os destinos de ${region.name}`,
    mapSubtitle:         `Explore visualmente os principais destinos da ${region.name.toLowerCase()} do Peru e descubra que experiências você pode viver em cada zona.`,
    destinationsEyebrow: 'Lugares emblemáticos',
    destinationsTitle:   `Principais destinos de ${region.name}`,
    featuredLabel:       'Destino em destaque',
    seeDestination:      'Ver destino →',
    packagesEyebrow:     'Experiências relacionadas',
    packagesTitle:       `Pacotes para viver ${region.name}`,
    packagesSubtitle:    'Roteiros criados para descobrir o território com organização, tempo e propósito.',
    toursTitle:          'Tours para explorar em menos tempo',
    toursSubtitle:       'Experiências curtas para conectar com lugares essenciais desta região.',
    storyEyebrow:        'Cultura e essência',
    storyTitle:          'Uma região para vivenciar o Peru de outra perspectiva',
    storyBody:           `Além das suas paisagens, esta região convida a conectar com a identidade do Peru: seus caminhos, sua gente, seus sabores e sua forma de receber cada viajante.`,
    ctaTitle:            `Quer descobrir a ${region.name.toLowerCase()} do Peru à sua maneira?`,
    ctaSubtitle:         'Criamos um roteiro personalizado de acordo com seus dias, interesses e forma de viajar.',
    ctaPrimary:          'Começar a planejar',
    ctaSecondary:        'Falar com um consultor',
    prevPackage:         'Pacote anterior',
    nextPackage:         'Próximo pacote',
    prevTour:            'Tour anterior',
    nextTour:            'Próximo tour',
  },

  fr: {
    eyebrow:             'Destinations du Pérou',
    exploreDestinations: 'Explorer les destinations',
    designTrip:          'Créer mon voyage',
    contactHref:         `/${locale}/contact`,
    mapTitle:            `Localisez les destinations de ${region.name}`,
    mapSubtitle:         `Explorez visuellement les principales destinations de la ${region.name.toLowerCase()} du Pérou et découvrez les expériences que vous pouvez vivre dans chaque zone.`,
    destinationsEyebrow: 'Lieux emblématiques',
    destinationsTitle:   `Destinations principales de ${region.name}`,
    featuredLabel:       'Destination phare',
    seeDestination:      'Voir la destination →',
    packagesEyebrow:     'Expériences associées',
    packagesTitle:       `Forfaits pour vivre ${region.name}`,
    packagesSubtitle:    'Des itinéraires conçus pour découvrir le territoire avec organisation, temps et sens.',
    toursTitle:          'Tours à explorer en moins de temps',
    toursSubtitle:       "De courtes expériences pour se connecter avec les lieux essentiels de cette région.",
    storyEyebrow:        'Culture et essence',
    storyTitle:          'Une région pour vivre le Pérou sous un autre angle',
    storyBody:           `Au-delà de ses paysages, cette région invite à se connecter avec l'identité du Pérou : ses chemins, ses habitants, ses saveurs et sa façon d'accueillir chaque voyageur.`,
    ctaTitle:            `Vous souhaitez découvrir la ${region.name.toLowerCase()} du Pérou à votre façon ?`,
    ctaSubtitle:         "Nous concevons un itinéraire personnalisé en fonction de vos jours, de vos centres d'intérêt et de votre style de voyage.",
    ctaPrimary:          'Commencer à planifier',
    ctaSecondary:        'Parler à un conseiller',
    prevPackage:         'Forfait précédent',
    nextPackage:         'Forfait suivant',
    prevTour:            'Tour précédent',
    nextTour:            'Tour suivant',
  },
};

const copy = copyByLocale[locale];

const pageTitle       = region.seoTitle       || `${region.name} | Nuna Terra Perú`;
const pageDescription = region.seoDescription || region.description || region.headline;
---

<BaseLayout title={pageTitle} description={pageDescription}>

  <!-- HERO -->
  <section class="region-hero">
    <img
      src={heroImage}
      alt={region.name}
      class="region-hero__image"
      loading="eager"
      fetchpriority="high"
    />

    <div class="region-hero__overlay"></div>

    <div class="container region-hero__content">
      <p class="region-hero__eyebrow">{copy.eyebrow}</p>

      <h1>{region.name}</h1>

      <p>{region.headline || region.description}</p>

      <div class="region-hero__actions">
        <a href="#destinos" class="region-btn region-btn--primary">
          {copy.exploreDestinations}
        </a>

        <a href={copy.contactHref} class="region-btn region-btn--ghost">
          {copy.designTrip}
        </a>
      </div>
    </div>
  </section>

  <!-- QUOTE -->
  <section class="region-quote" data-animate="fade-up">
    <div class="container region-quote__inner">
      <p>
        "{region.description ||
          `${region.name} brings together landscapes, culture and experiences that reveal a deep way of living the country.`}"
      </p>
    </div>
  </section>

  <!-- MAP -->
  <section class="region-map-section" data-animate="fade-up">
    <div class="container">
      <PeruRegionMap
        destinations={mapDestinations}
        region={region.slug}
        allRegions={allRegions}
        title={copy.mapTitle}
        subtitle={copy.mapSubtitle}
      />
    </div>
  </section>

  <!-- DESTINATIONS -->
  <section class="region-section region-destinations" id="destinos">
    <div class="container">
      <SectionHeading
        eyebrow={copy.destinationsEyebrow}
        title={copy.destinationsTitle}
        subtitle={region.description}
        align="left"
      />

      {regionDestinations.length > 0 && (
        <div class="region-destinations__layout" data-animate="fade-up">
          {featuredDestination && (
            <article class="region-destination-main">
              <a href={`/${locale}/destinations/${featuredDestination.slug}`}>
                <img
                  src={featuredDestination.cardImage || featuredDestination.heroImage || '/images/placeholders/destination-placeholder.jpg'}
                  alt={featuredDestination.name}
                  loading="lazy"
                />

                <div>
                  <span>{copy.featuredLabel}</span>
                  <h3>{featuredDestination.name}</h3>
                  <p>
                    {featuredDestination.subtitle ||
                      featuredDestination.shortDescription ||
                      featuredDestination.description}
                  </p>
                  <b>{copy.seeDestination}</b>
                </div>
              </a>
            </article>
          )}

          <div class="region-destination-list">
            {secondaryDestinations.map((destination) => (
              <article class="region-destination-mini">
                <a href={`/${locale}/destinations/${destination.slug}`}>
                  <img
                    src={destination.cardImage || destination.heroImage || '/images/placeholders/destination-placeholder.jpg'}
                    alt={destination.name}
                    loading="lazy"
                  />

                  <div>
                    <h3>{destination.name}</h3>
                    <span>{destination.region}</span>
                    <b>{copy.seeDestination}</b>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- PACKAGES CAROUSEL -->
  {packages.length > 0 && (
    <section class="region-section region-products" id="experiencias" data-animate="fade-up">
      <div class="container">
        <SectionHeading
          eyebrow={copy.packagesEyebrow}
          title={copy.packagesTitle}
          subtitle={copy.packagesSubtitle}
          centered
        />

        <div class="region-carousel" data-carousel>
          <div class="region-carousel__track" data-track>
            {packages.map((product) => (
              <div class="region-carousel__slide">
                <ProductCard product={product} />
              </div>
            ))}
          </div>

          <div class="region-carousel__footer">
            <button
              class="region-carousel__arrow"
              data-prev
              aria-label={copy.prevPackage}
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="15 18 9 12 15 6"/>
              </svg>
            </button>

            <div class="region-carousel__dots" data-dots></div>

            <button
              class="region-carousel__arrow"
              data-next
              aria-label={copy.nextPackage}
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- TOURS CAROUSEL -->
  {tours.length > 0 && (
    <section class="region-section region-tours" data-animate="fade-up">
      <div class="container">
        <SectionHeading
          title={copy.toursTitle}
          subtitle={copy.toursSubtitle}
          align="left"
        />

        <div class="region-carousel region-carousel--tours" data-carousel>
          <div class="region-carousel__track" data-track>
            {tours.map((product) => (
              <div class="region-carousel__slide">
                <ProductCard product={product} />
              </div>
            ))}
          </div>

          <div class="region-carousel__footer">
            <button
              class="region-carousel__arrow"
              data-prev
              aria-label={copy.prevTour}
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="15 18 9 12 15 6"/>
              </svg>
            </button>

            <div class="region-carousel__dots" data-dots></div>

            <button
              class="region-carousel__arrow"
              data-next
              aria-label={copy.nextTour}
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- STORY -->
  <section class="region-story">
    <div class="container region-story__grid">
      <div class="region-story__image" data-animate="slide-left">
        <img src={storyImage} alt={region.name} loading="lazy" />
      </div>

      <div class="region-story__content" data-animate="slide-right">
        <p class="eyebrow">{copy.storyEyebrow}</p>

        <h2>{copy.storyTitle}</h2>

        <p>
          {region.description || copy.storyBody}
        </p>

        {region.headline && (
          <blockquote>"{region.headline}"</blockquote>
        )}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="region-final-cta" data-animate="fade-up">
    <div class="container region-final-cta__inner">
      <h2>{copy.ctaTitle}</h2>
      <p>{copy.ctaSubtitle}</p>

      <div>
        <a href={copy.contactHref} class="region-btn region-btn--primary">
          {copy.ctaPrimary}
        </a>

        <a href={copy.contactHref} class="region-btn region-btn--ghost">
          {copy.ctaSecondary}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
/* =====================================================
   SCROLL ANIMATIONS — IntersectionObserver
===================================================== */
function initAnimations(): void {
  const els = document.querySelectorAll<HTMLElement>('[data-animate]');
  if (!els.length) return;

  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -56px 0px' }
  );

  els.forEach((el) => io.observe(el));
}

/* =====================================================
   CAROUSEL
===================================================== */
class Carousel {
  private el: HTMLElement;
  private track: HTMLElement;
  private slides: HTMLElement[];
  private dots: HTMLElement | null;
  private prevBtn: HTMLButtonElement | null;
  private nextBtn: HTMLButtonElement | null;
  private current: number = 0;
  private timer: ReturnType<typeof setInterval> | null = null;
  private readonly gap: number = 24;
  private readonly interval: number = 5000;

  constructor(el: HTMLElement) {
    this.el = el;
    this.track = el.querySelector<HTMLElement>('[data-track]')!;
    this.slides = Array.from(this.track.querySelectorAll<HTMLElement>('.region-carousel__slide'));
    this.dots = el.querySelector<HTMLElement>('[data-dots]');
    this.prevBtn = el.querySelector<HTMLButtonElement>('[data-prev]');
    this.nextBtn = el.querySelector<HTMLButtonElement>('[data-next]');

    if (!this.slides.length) return;

    this.setup();
    this.render();
    this.startTimer();
  }

  private perView(): number {
    if (window.innerWidth >= 980) return 3;
    if (window.innerWidth >= 640) return 2;
    return 1;
  }

  private totalPages(): number {
    return Math.max(1, this.slides.length - this.perView() + 1);
  }

  private setup(): void {
    const pv = this.perView();

    if (this.slides.length <= pv) {
      this.track.style.display = 'grid';
      this.track.style.gridTemplateColumns = `repeat(${this.slides.length}, 1fr)`;
      this.el.querySelector<HTMLElement>('.region-carousel__footer')?.remove();
      return;
    }

    this.buildDots();
    this.bindEvents();

    window.addEventListener('resize', () => {
      this.current = 0;
      this.render();
      this.buildDots();
    });
  }

  private buildDots(): void {
    if (!this.dots) return;
    this.dots.innerHTML = '';
    const total = this.totalPages();
    for (let i = 0; i < total; i++) {
      const btn = document.createElement('button');
      btn.className = 'region-carousel__dot';
      btn.setAttribute('aria-label', `${i + 1}`);
      btn.addEventListener('click', () => { this.go(i); this.resetTimer(); });
      this.dots.appendChild(btn);
    }
    this.syncDots();
  }

  private syncDots(): void {
    this.dots?.querySelectorAll('.region-carousel__dot').forEach((d, i) => {
      d.classList.toggle('is-active', i === this.current);
    });
    if (this.prevBtn) this.prevBtn.disabled = this.current === 0;
    if (this.nextBtn) this.nextBtn.disabled = this.current >= this.totalPages() - 1;
  }

  private render(): void {
    const slideW = this.slides[0]?.offsetWidth ?? 0;
    const offset = this.current * (slideW + this.gap);
    this.track.style.transform = `translateX(-${offset}px)`;
    this.syncDots();
  }

  go(idx: number): void {
    this.current = Math.max(0, Math.min(idx, this.totalPages() - 1));
    this.render();
  }

  next(): void {
    this.go(this.current >= this.totalPages() - 1 ? 0 : this.current + 1);
  }

  prev(): void {
    this.go(this.current <= 0 ? this.totalPages() - 1 : this.current - 1);
  }

  private bindEvents(): void {
    this.prevBtn?.addEventListener('click', () => { this.prev(); this.resetTimer(); });
    this.nextBtn?.addEventListener('click', () => { this.next(); this.resetTimer(); });

    this.el.addEventListener('mouseenter', () => this.stopTimer());
    this.el.addEventListener('mouseleave', () => this.startTimer());
    this.el.addEventListener('focusin',    () => this.stopTimer());
    this.el.addEventListener('focusout',   () => {
      if (!this.el.contains(document.activeElement)) this.startTimer();
    });

    let startX = 0;
    this.track.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
    }, { passive: true });
    this.track.addEventListener('touchend', (e) => {
      const delta = startX - e.changedTouches[0].clientX;
      if (Math.abs(delta) > 48) {
        delta > 0 ? this.next() : this.prev();
        this.resetTimer();
      }
    });
  }

  private startTimer(): void {
    this.timer = setInterval(() => this.next(), this.interval);
  }

  private stopTimer(): void {
    if (this.timer) clearInterval(this.timer);
    this.timer = null;
  }

  private resetTimer(): void {
    this.stopTimer();
    this.startTimer();
  }
}

/* =====================================================
   BOOT
===================================================== */
function boot(): void {
  initAnimations();

  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((el) => {
    if (!el.dataset.ready) {
      el.dataset.ready = '1';
      new Carousel(el);
    }
  });
}

document.addEventListener('DOMContentLoaded', boot);
document.addEventListener('astro:page-load', boot);
</script>
