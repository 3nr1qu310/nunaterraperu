---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import ProductCard from '@/components/cards/ProductCard.astro';
import LucideIcon from '@/components/cards/LucideIcon.astro';
import { getTours, getTravelCategories } from '@/lib/content';
import { getSiteSettings } from '@/lib/settings';
import { isLocale, type Locale } from '@/lib/i18n';
import { site } from '@/lib/site';
import '../../tours/TourIndex.scss';

export const prerender = false;

const localeParam = Astro.params.locale;

if (!isLocale(localeParam)) {
  return Astro.redirect('/tours');
}

const locale = localeParam as Locale;

const [tours, allCategories, settings] = await Promise.all([
  getTours(locale),
  getTravelCategories(),
  getSiteSettings(['tours_hero_video']),
]);

const heroVideo = settings['tours_hero_video'] || '';

/* Hero con imágenes reales de los tours */
const featuredHeroTour = tours.find((t) => t.featured) || tours[0] || null;

const heroImage =
  featuredHeroTour?.heroImage ||
  featuredHeroTour?.cardImage ||
  '/images/tours-hero.jpg';

const customCtaImage = tours[1]?.heroImage || heroImage;

const activeCategorySlugs = new Set(tours.flatMap((t) => t.categorySlugs || []));
const activeCategories = allCategories.filter((cat) => activeCategorySlugs.has(cat.slug));
const uniqueDestinations = new Set(tours.flatMap((t) => t.destinations || []));

const baseMarquee = uniqueDestinations.size >= 5
  ? Array.from(uniqueDestinations)
  : ['Cusco', 'Machu Picchu', 'Lago Titicaca', 'Arequipa', 'Lima', 'Nazca', 'Iquitos', 'Valle Sagrado', 'Cañón del Colca', 'Huaraz', 'Ollantaytambo'];
const marqueeItems = [...baseMarquee, ...baseMarquee];
const marqueeDuration = `${Math.max(32, baseMarquee.length * 4)}s`;

const categoryGroups = activeCategories
  .map((cat) => ({ ...cat, tours: tours.filter((t) => t.categorySlugs?.includes(cat.slug)) }))
  .filter((g) => g.tours.length > 0);

const copyByLocale = {
  en: {
    pageTitle: 'Tours in Peru | Nuna Terra Perú',
    pageDescription: 'One-day experiences to discover the most emblematic destinations in Peru with guides, transport and organization included.',
    heroAlt: 'Travelers on a mountain trail in Peru',
    heroEyebrow: 'Tours and experiences',
    heroTitle: 'Live Peru\nin every day',
    heroTitleEm: 'in every day',
    heroSubtitle: 'Excursions with transport, local guide and entrance fees included. Organized so you just enjoy.',
    heroBtn: 'View all tours',
    heroWhatsapp: 'Ask on WhatsApp ↗',
    regionsEyebrow: 'Destinations',
    regionsTitle: 'The Peru that awaits you',
    regionsSubtitle: 'Three regions, three different worlds. Each with its own character, rhythm and landscapes unlike anything you have seen before.',
    regions: [
      { slug: 'sierra', name: 'Sierra', tagline: 'Andes & altitude', description: 'Cusco, the Sacred Valley, Machu Picchu and Lake Titicaca. Living Inca culture, ancient routes and landscapes above 3,000 metres.' },
      { slug: 'costa', name: 'Coast', tagline: 'Coastline & mystery', description: 'Lima and its world-class gastronomy, the enigmatic Nazca Lines, the Caral pyramids and civilizations that preceded the Incas.' },
      { slug: 'selva', name: 'Jungle', tagline: 'Living Amazon', description: 'Iquitos, the Amazon River and the most biodiverse ecosystem on the planet. A green, infinite adventure that challenges every sense.' },
    ],
    tourSingular: 'tour',
    tourPlural: 'tours',
    available: 'available',
    exploreCta: 'Explore →',
    statTours: 'Tours available',
    statDestinations: 'Destinations',
