    nextTour: 'Tour suivant',
    emptyTitle: 'Catalogue en préparation',
    emptyText: `Nous aurons bientôt des expériences disponibles. Contactez-nous pour plus d'informations.`,
    processEyebrow: 'Simple par conception',
