    steps: [
      { num: '01', icon: 'search', title: 'Choisissez votre expérience', description: 'Parcourez le catalogue et filtrez par région, type de tour ou durée. Des sorties de demi-journée à trois jours complets.' },
      { num: '02', icon: 'message-circle', title: 'Coordonnez les détails', description: 'Un conseiller Nuna Terra répond en moins de 24 heures pour confirmer les disponibilités et ajuster tout détail.' },
      { num: '03', icon: 'compass', title: 'Vivez le Pérou', description: 'Guide local certifié, transport confortable et entrées incluses. Vous arrivez simplement — nous nous occupons du reste.' },
    ],
    trustEyebrow: 'Pourquoi nous choisir',
    trustTitle: 'Chaque détail a une raison',
    trustItems: [
      { icon: 'compass', title: 'Guides avec leur propre histoire', description: "Nous ne lisons pas de scripts. Nos guides ont grandi ou travaillé pendant des années dans chaque destination. Ils connaissent des raccourcis, des histoires et des perspectives qu'aucun livre ne contient." },
      { icon: 'shield', title: 'Prix clair, sans surprises', description: "Ce que vous voyez est ce que vous payez. Tout — transport, guide et entrées — est détaillé avant la réservation. Pas de frais supplémentaires à l'arrivée." },
      { icon: 'users', title: 'Petits groupes', description: "Maximum 12 personnes par départ. Une vraie expérience, pas une excursion de masse où vous n'êtes qu'un numéro dans la file." },
      { icon: 'clock', title: 'Ponctualité comme norme', description: "Prise en charge à votre hôtel à l'heure convenue. Véhicules modernes avec climatisation et conducteurs qui connaissent chaque virage de la route." },
    ],
    customEyebrow: 'Expériences uniques',
    customTitle: "Vous cherchez quelque chose\nqui n'est pas au catalogue ?",
    customSubtitle: "Nous concevons des excursions sur mesure selon vos jours, vos intérêts et la taille de votre groupe. Un conseiller Nuna Terra travaille avec vous pour créer le parcours parfait.",
    customBtn: 'Concevoir mon tour',
    customWhatsapp: 'Parler sur WhatsApp ↗',
    contactHref: '/fr/contact',
  },
};

const copy = copyByLocale[locale];
---

<BaseLayout title={copy.pageTitle} description={copy.pageDescription}>

  <!-- HERO -->
  <section class="tri-hero" aria-label={copy.heroEyebrow}>
    {heroVideo ? (
      <video class="tri-hero__bg" data-deferred-video={heroVideo} preload="none" muted loop playsinline poster={heroImage} />
    ) : (
      <img class="tri-hero__bg" src={heroImage} alt={featuredHeroTour?.title || copy.heroAlt} loading="eager" fetchpriority="high" decoding="async" />
    )}
    <div class="tri-hero__overlay" aria-hidden="true"></div>

    <div class="container tri-hero__content">
      <p class="tri-hero__eyebrow">
        <span class="tri-hero__dot" aria-hidden="true"></span>
        {copy.heroEyebrow}
      </p>
      <h1 class="tri-hero__title" set:html={copy.heroTitle.replace(copy.heroTitleEm, `<em>${copy.heroTitleEm}</em>`).replace('\n', '<br />')} />
      <p class="tri-hero__subtitle">{copy.heroSubtitle}</p>
      <div class="tri-hero__actions">
        <a href="#catalogo" class="tri-hero__btn tri-hero__btn--primary">{copy.heroBtn}</a>
        <a href={site.whatsappUrl} class="tri-hero__btn tri-hero__btn--ghost" target="_blank" rel="noopener noreferrer">{copy.heroWhatsapp}</a>
      </div>
    </div>

    <div class="tri-hero__scroll" aria-hidden="true">
      <span class="tri-hero__scroll-line"></span>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="tri-marquee" aria-hidden="true">
    <div class="tri-marquee__track" style={`--duration: ${marqueeDuration}`}>
      {marqueeItems.map((dest) => (
        <>
          <span class="tri-marquee__item">{dest}</span>
          <span class="tri-marquee__sep">✦</span>
        </>
      ))}
    </div>
  </div>

  <!-- REGIONS -->
  <section class="tri-regions" aria-labelledby="tri-regions-title">
    <div class="container">
      <div class="tri-regions__head">
        <p class="tri-regions__eyebrow">{copy.regionsEyebrow}</p>
        <h2 class="tri-regions__title" id="tri-regions-title">{copy.regionsTitle}</h2>
        <p class="tri-regions__subtitle">{copy.regionsSubtitle}</p>
      </div>
      <div class="tri-regions__grid">
        {copy.regions.map((region, i) => {
          const toursCount = tours.filter((t) => t.region === region.slug).length;
          return (
            <article class="tri-region-card reveal-item" data-delay={i * 100}>
              <div class="tri-region-card__media">
                <img
                  src={`https://picsum.photos/seed/${region.slug}peru2024/700/950`}
                  alt={`${region.name} — ${region.tagline}`}
                  loading="lazy"
                  class="tri-region-card__img"
                />
                <div class="tri-region-card__shade" aria-hidden="true"></div>
              </div>
              <div class="tri-region-card__body">
                <p class="tri-region-card__tagline">{region.tagline}</p>
                <h3 class="tri-region-card__name">{region.name}</h3>
                <p class="tri-region-card__desc">{region.description}</p>
                {toursCount > 0 && (
                  <p class="tri-region-card__count">
                    {toursCount} {toursCount === 1 ? copy.tourSingular : copy.tourPlural} {copy.available}
                  </p>
                )}
                <a href="#catalogo" class="tri-region-card__cta">{copy.exploreCta}</a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- STATS -->
  <div class="tri-stats">
    <div class="container tri-stats__inner">
      <div class="tri-stat">
        <strong>{tours.length}</strong>
        <span>{copy.statTours}</span>
      </div>
      <div class="tri-stat">
        <strong>{uniqueDestinations.size}</strong>
        <span>{copy.statDestinations}</span>
      </div>
      {activeCategories.length > 0 && (
        <div class="tri-stat">
          <strong>{activeCategories.length}</strong>
          <span>{copy.statStyles}</span>
        </div>
      )}
      <div class="tri-stat">
        <strong>1–3</strong>
        <span>{copy.statDuration}</span>
      </div>
      <div class="tri-stat">
        <strong>≤12</strong>
        <span>{copy.statGroup}</span>
      </div>
    </div>
  </div>

  <!-- CATALOG -->
  <div class="tri-catalog-wrap" id="catalogo">
    <div class="container">
      <div class="tri-catalog__head">
        <div class="tri-catalog__head-left">
          <p class="tri-catalog__eyebrow">{copy.catalogEyebrow}</p>
          <h2 class="tri-catalog__title">{copy.catalogTitle}</h2>
        </div>
        <p class="tri-catalog__subtitle">{copy.catalogSubtitle}</p>
      </div>
    </div>

    {categoryGroups.length > 1 && (
      <div class="tri-filter-bar">
        <div class="container">
          <nav class="tri-filter-pills">
            {categoryGroups.map((group) => (
              <a href={`#tcat-section-${group.slug}`} class="tri-filter-pill" data-filter={group.slug}>
                {group.name}
              </a>
            ))}
          </nav>
        </div>
      </div>
    )}

    {categoryGroups.length > 0 ? (
      <div class="tcat-list">
        {categoryGroups.map((group, gi) => (
          <section class="tcat-section" id={`tcat-section-${group.slug}`} data-section-index={gi} aria-labelledby={`tcat-title-${group.slug}`}>
            {group.heroImage && (
              <div class="tcat-section__bg" aria-hidden="true">
                <img src={group.heroImage} alt="" loading="lazy" />
              </div>
            )}
            <div class="container">
              <div class="tcat-layout">
                <div class="tcat-header" data-section-index={gi}>
                  <div class="tcat-header__meta">
                    <p class="tcat-intro__eyebrow">{copy.travelStyle}</p>
                    <div class="tcat-header__name-row">
                      <div class="tcat-icon-wrap" aria-hidden="true">
                        <LucideIcon name={group.icon || 'compass'} size={22} class="tcat-icon" />
                      </div>
                      <h3 class="tcat-name" id={`tcat-title-${group.slug}`}>{group.name}</h3>
                    </div>
                    {group.description && <p class="tcat-desc">{group.description}</p>}
                  </div>
                  <div class="tcat-count">
                    <strong class="tcat-count__num">{group.tours.length}</strong>
                    <span>{copy.available2(group.tours.length)}</span>
                  </div>
                </div>

                <div class="tcat-carousel-outer" data-carousel-id={group.slug}>
                  <button class="tcat-nav tcat-nav--prev" aria-label={copy.prevTour} type="button" disabled>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
                  </button>
                  <div class="tcat-tours" id={`tcat-tours-${group.slug}`}>
                    {group.tours.map((tour, ti) => (
                      <div class={`tcat-card-wrap${group.tours.length === 1 ? ' tcat-card-wrap--wide' : ''}`} data-card-i={ti}>
                        <ProductCard product={tour} />
                      </div>
                    ))}
                  </div>
                  <button class="tcat-nav tcat-nav--next" aria-label={copy.nextTour} type="button">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                  </button>
                  <div class="tcat-progress" aria-hidden="true">
                    <div class="tcat-progress__track"><div class="tcat-progress__fill"></div></div>
                    <span class="tcat-progress__count"></span>
                  </div>
                </div>
              </div>
            </div>
          </section>
        ))}
      </div>
    ) : (
      <div class="container">
        <div class="tri-empty">
          <div class="tri-empty__icon" aria-hidden="true">⌖</div>
          <h3 class="tri-empty__title">{copy.emptyTitle}</h3>
          <p class="tri-empty__text">{copy.emptyText}</p>
        </div>
      </div>
    )}
  </div>

  <!-- HOW IT WORKS -->
  <section class="tri-process" aria-labelledby="tri-process-title">
    <div class="container">
      <div class="tri-process__head">
        <p class="tri-process__eyebrow">{copy.processEyebrow}</p>
        <h2 class="tri-process__title" id="tri-process-title">{copy.processTitle}</h2>
      </div>
      <div class="tri-process__steps">
        {copy.steps.map((step, i) => (
          <div class="tri-step reveal-item" data-delay={i * 110}>
            <div class="tri-step__num" aria-hidden="true">{step.num}</div>
            <div class="tri-step__icon-wrap" aria-hidden="true">
              <LucideIcon name={step.icon} size={22} class="tri-step__icon" />
            </div>
            <h3 class="tri-step__title">{step.title}</h3>
            <p class="tri-step__desc">{step.description}</p>
            {i < copy.steps.length - 1 && (
              <div class="tri-step__connector" aria-hidden="true">
                <span class="tri-step__connector-line"></span>
                <span class="tri-step__connector-arrow">→</span>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY NUNA TERRA -->
  <section class="tri-trust" aria-labelledby="tri-trust-title">
    <div class="container">
      <div class="tri-trust__head">
        <p class="tri-trust__eyebrow">{copy.trustEyebrow}</p>
        <h2 class="tri-trust__title" id="tri-trust-title">{copy.trustTitle}</h2>
      </div>
      <div class="tri-trust__grid">
        {copy.trustItems.map((item, i) => (
          <div class="tri-trust-item reveal-item" data-delay={i * 80}>
            <div class="tri-trust-item__icon-wrap" aria-hidden="true">
              <LucideIcon name={item.icon} size={20} class="tri-trust-item__icon" />
            </div>
            <h3 class="tri-trust-item__title">{item.title}</h3>
            <p class="tri-trust-item__desc">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CUSTOM CTA -->
  <section class="tri-custom" aria-labelledby="tri-custom-title">
    <div class="tri-custom__bg" aria-hidden="true">
      <img src={customCtaImage} alt="" loading="lazy" decoding="async" />
    </div>
    <div class="tri-custom__overlay" aria-hidden="true"></div>
    <div class="container tri-custom__content">
      <p class="tri-custom__eyebrow">{copy.customEyebrow}</p>
      <h2 class="tri-custom__title" id="tri-custom-title" set:html={copy.customTitle.replace('\n', '<br />')} />
      <p class="tri-custom__subtitle">{copy.customSubtitle}</p>
      <div class="tri-custom__actions">
        <a href={copy.contactHref} class="tri-custom__btn tri-custom__btn--primary">{copy.customBtn}</a>
        <a href={site.whatsappUrl} class="tri-custom__btn tri-custom__btn--ghost" target="_blank" rel="noopener noreferrer">{copy.customWhatsapp}</a>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      document.querySelectorAll('.tcat-tours').forEach((grid) => {
        grid.querySelectorAll('.tcat-card-wrap').forEach((card, i) => {
          card.style.setProperty('--card-delay', `${i * 100}ms`);
        });
      });

      if ('IntersectionObserver' in window) {
        const sectionObserver = new IntersectionObserver(
          (entries) => { entries.forEach((entry) => { if (entry.isIntersecting) { const el = entry.target; const delay = parseInt(el.dataset.delay || '0', 10); setTimeout(() => el.classList.add('is-visible'), delay); sectionObserver.unobserve(el); } }); },
          { threshold: 0.06, rootMargin: '0px 0px -20px 0px' }
        );
        document.querySelectorAll('.reveal-item').forEach((el) => sectionObserver.observe(el));

        const introObserver = new IntersectionObserver(
          (entries) => { entries.forEach((entry) => { if (entry.isIntersecting) { entry.target.classList.add('is-visible'); introObserver.unobserve(entry.target); } }); },
          { threshold: 0.12 }
        );
        document.querySelectorAll('.tcat-header').forEach((el) => introObserver.observe(el));

        const cardObserver = new IntersectionObserver(
          (entries) => { entries.forEach((entry) => { if (entry.isIntersecting) { entry.target.classList.add('is-card-visible'); cardObserver.unobserve(entry.target); } }); },
          { threshold: 0.04, rootMargin: '0px 0px -24px 0px' }
        );
        document.querySelectorAll('.tcat-card-wrap').forEach((card) => cardObserver.observe(card));
      } else {
        document.querySelectorAll('.reveal-item').forEach((el) => el.classList.add('is-visible'));
        document.querySelectorAll('.tcat-header').forEach((el) => el.classList.add('is-visible'));
        document.querySelectorAll('.tcat-card-wrap').forEach((card) => card.classList.add('is-card-visible'));
      }

      const filterBar = document.querySelector('.tri-filter-bar');
      if (filterBar) {
        const sentinel = document.createElement('div');
        sentinel.style.cssText = 'height:1px;pointer-events:none;position:absolute;top:0;left:0;right:0;';
        filterBar.parentElement.style.position = 'relative';
        filterBar.parentElement.insertBefore(sentinel, filterBar);
        new IntersectionObserver(([e]) => filterBar.classList.toggle('is-stuck', !e.isIntersecting), { threshold: 1 }).observe(sentinel);

        const pills = document.querySelectorAll('.tri-filter-pill');
        const sections = document.querySelectorAll('.tcat-section[id]');
        sections.forEach((s) => {
          new IntersectionObserver(([e]) => {
            if (e.isIntersecting) { const id = e.target.id; pills.forEach((p) => { p.classList.toggle('is-active', p.getAttribute('href') === `#${id}`); }); }
          }, { threshold: 0.35, rootMargin: '-10% 0px -55% 0px' }).observe(s);
        });
      }

      document.querySelectorAll('.tcat-carousel-outer').forEach((outer) => {
        const track = outer.querySelector('.tcat-tours');
        const prevBtn = outer.querySelector('.tcat-nav--prev');
        const nextBtn = outer.querySelector('.tcat-nav--next');
        const fill = outer.querySelector('.tcat-progress__fill');
        const countEl = outer.querySelector('.tcat-progress__count');
        const cards = outer.querySelectorAll('.tcat-card-wrap');
        if (!track || !cards.length) return;
        const getCardWidth = () => { const c = cards[0]; if (!c) return 300; const gap = parseInt(getComputedStyle(track).gap) || 20; return c.offsetWidth + gap; };
        const update = () => {
          const maxScroll = track.scrollWidth - track.clientWidth;
          if (prevBtn) prevBtn.disabled = track.scrollLeft < 4;
          if (nextBtn) nextBtn.disabled = track.scrollLeft >= maxScroll - 4;
          if (fill) { const pct = maxScroll <= 0 ? 100 : (track.scrollLeft / maxScroll) * 100; fill.style.width = `${Math.max(8, Math.min(100, pct))}%`; }
          if (countEl) { const w = getCardWidth(); const idx = w > 0 ? Math.round(track.scrollLeft / w) + 1 : 1; countEl.textContent = `${Math.min(idx, cards.length)} / ${cards.length}`; }
        };
        const checkScrollable = () => { outer.toggleAttribute('data-scrollable', track.scrollWidth > track.clientWidth + 8); update(); };
        prevBtn?.addEventListener('click', () => track.scrollBy({ left: -getCardWidth(), behavior: 'smooth' }));
        nextBtn?.addEventListener('click', () => track.scrollBy({ left: getCardWidth(), behavior: 'smooth' }));
        track.addEventListener('scroll', update, { passive: true });
        let isDragging = false, startX = 0, startScroll = 0;
        track.addEventListener('mousedown', (e) => { isDragging = true; startX = e.pageX - track.offsetLeft; startScroll = track.scrollLeft; track.classList.add('is-dragging'); });
        window.addEventListener('mousemove', (e) => { if (!isDragging) return; e.preventDefault(); track.scrollLeft = startScroll - (e.pageX - track.offsetLeft - startX); });
        window.addEventListener('mouseup', () => { isDragging = false; track.classList.remove('is-dragging'); });
        checkScrollable();
        if ('ResizeObserver' in window) new ResizeObserver(checkScrollable).observe(track);
        countEl && (countEl.textContent = `1 / ${cards.length}`);

        let autoTimer = null;
        const autoAdvance = () => { const maxScroll = track.scrollWidth - track.clientWidth; if (maxScroll <= 0) return; if (track.scrollLeft >= maxScroll - 4) { track.scrollTo({ left: 0, behavior: 'smooth' }); } else { track.scrollBy({ left: getCardWidth(), behavior: 'smooth' }); } };
        const startAuto = () => { if (autoTimer) return; autoTimer = setInterval(autoAdvance, 4500); };
        const stopAuto = () => { clearInterval(autoTimer); autoTimer = null; };
        outer.addEventListener('mouseenter', stopAuto);
        outer.addEventListener('mouseleave', startAuto);
        outer.addEventListener('touchstart', () => { stopAuto(); setTimeout(startAuto, 6000); }, { passive: true });
        startAuto();
      });

      document.querySelectorAll('a[href^="#"]').forEach((a) => {
        a.addEventListener('click', (e) => {
          const target = document.querySelector(a.getAttribute('href'));
          if (!target) return;
          e.preventDefault();
          const top = target.getBoundingClientRect().top + window.scrollY - 56;
          window.scrollTo({ top, behavior: 'smooth' });
        });
      });
    })();
  </script>

</BaseLayout>
