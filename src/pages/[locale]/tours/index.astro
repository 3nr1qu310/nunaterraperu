    customTitle: 'Procura algo que\nnão está no catálogo?',
    customSubtitle: 'Criamos excursões personalizadas de acordo com seus dias, interesses e tamanho do grupo. Um consultor da Nuna Terra trabalha com você para criar a rota perfeita.',
    customBtn: 'Criar meu tour',
    customWhatsapp: 'Falar pelo WhatsApp ↗',
    contactHref: '/pt/contact',
  },
  fr: {
    pageTitle: 'Tours au Pérou | Nuna Terra Perú',
    pageDescription: "Des expériences d'un jour pour découvrir les destinations les plus emblématiques du Pérou avec guides, transport et organisation inclus.",
    heroAlt: 'Voyageurs sur un sentier de montagne au Pérou',
    heroEyebrow: 'Tours et expériences',
    heroTitle: 'Vivez le Pérou\nà chaque journée',
    heroTitleEm: 'à chaque journée',
    heroSubtitle: "Excursions avec transport, guide local et entrées incluses. Organisées pour que vous profitiez simplement.",
    heroBtn: 'Voir tous les tours',
    heroWhatsapp: 'Consulter sur WhatsApp ↗',
    regionsEyebrow: 'Destinations',
    regionsTitle: 'Le Pérou qui vous attend',
    regionsSubtitle: "Trois régions, trois mondes différents. Chacune avec son caractère, son rythme et des paysages comme vous n'en avez jamais vus.",
    regions: [
      { slug: 'sierra', name: 'Sierra', tagline: 'Andes & altitude', description: 'Cusco, la Vallée Sacrée, le Machu Picchu et le lac Titicaca. Culture inca vivante, routes millénaires et paysages à plus de 3 000 mètres.' },
      { slug: 'costa', name: 'Côte', tagline: 'Littoral & mystère', description: 'Lima et sa gastronomie de classe mondiale, les énigmatiques lignes de Nazca, les pyramides de Caral et des civilisations qui précédèrent les Incas.' },
      { slug: 'selva', name: 'Amazonie', tagline: 'Amazonie vivante', description: "Iquitos, le fleuve Amazone et l'écosystème le plus biodiversifié de la planète. Une aventure verte et infinie qui défie tous les sens." },
    ],
    tourSingular: 'tour',
    tourPlural: 'tours',
    available: 'disponibles',
    exploreCta: 'Explorer →',
    statTours: 'Tours disponibles',
    statDestinations: 'Destinations',
    statStyles: 'Styles de voyage',
    statDuration: 'Jours de durée',
    statGroup: 'Personnes par groupe',
    catalogEyebrow: 'Catalogue complet',
    catalogTitle: 'Trouvez votre expérience',
